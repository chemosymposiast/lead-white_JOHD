                                                  <xs:element ref="thesu:customElement"
                                                  minOccurs="0" maxOccurs="unbounded"/>
                                                  </xs:sequence>
                                                  <xs:attribute ref="thesu:microThemeTag"
                                                  use="required"/>
                                                  <xs:attribute ref="thesu:focus" default="1"/>
                                                  <xs:attribute ref="thesu:rank"/>
                                                  </xs:restriction>
                                                  </xs:complexContent>
                                                  </xs:complexType>
                                                  </xs:element>
                                                  </xs:sequence>
                                                  <xs:attributeGroup
                                                  ref="thesu:uncertainWithComment"/>
                                                  </xs:restriction>
                                                  </xs:complexContent>
                                                  </xs:complexType>
                                                  </xs:element>
                                                </xs:sequence>
                                                <xs:attribute ref="thesu:comment"/>
                                              </xs:restriction>
                                            </xs:complexContent>
                                          </xs:complexType>
                                        </xs:element>
                                      </xs:choice>
                                      <xs:element name="paraphrasis" type="thesu:paraphrasis"
                                        minOccurs="0">
                                        <xs:annotation>
                                          <xs:documentation>Please, refer to the 'paraphrasis'
                                            complexType.</xs:documentation>
                                        </xs:annotation>
                                      </xs:element>
                                      <xs:element ref="thesu:customElement" minOccurs="0"
                                        maxOccurs="unbounded"/>
                                    </xs:sequence>
                                    <xs:attribute ref="thesu:cause" default="false"/>
                                    <xs:attribute ref="thesu:end" default="false"/>
                                    <xs:attributeGroup ref="thesu:uncertainWithComment"/>
                                  </xs:restriction>
                                </xs:complexContent>
                              </xs:complexType>
                            </xs:element>
                            <xs:element ref="thesu:customElement" minOccurs="0"
                              maxOccurs="unbounded"/>
                          </xs:sequence>
                        </xs:restriction>
                      </xs:complexContent>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:restriction>
            </xs:complexContent>
          </xs:complexType>
        </xs:element>
        <xs:element name="analogiesGroup">
          <xs:annotation>
            <xs:documentation>Please, refer to the 'analogiesGroup' complexType</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:complexContent>
              <xs:restriction base="thesu:analogiesGroup">
                <xs:sequence>
                  <xs:element name="analogy" minOccurs="0" maxOccurs="unbounded">
                    <xs:annotation>
                      <xs:documentation>Please, refer to the 'analogy'
                        complexType</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:complexContent>
                        <xs:restriction base="thesu:analogy">
                          <xs:sequence>
                            <xs:element ref="thesu:marker" minOccurs="0"/>
                            <xs:element name="analogyMember" maxOccurs="unbounded">
                              <xs:annotation>
                                <xs:documentation>Please, refer to the 'analogyMember'
                                  complexType</xs:documentation>
                              </xs:annotation>
                              <xs:complexType>
                                <xs:complexContent>
                                  <xs:restriction base="thesu:analogyMember">
                                    <xs:sequence>
                                      <xs:choice>
                                        <xs:element ref="thesu:textRef"/>
                                        <xs:element ref="thesu:fullyThemedTextRef"/>
                                        <xs:element name="elementRef" type="thesu:elementRef">
                                          <xs:annotation>
                                            <xs:documentation>Please refer to the 'elementRef'
                                              complexType.</xs:documentation>
                                          </xs:annotation>
                                        </xs:element>
                                        <xs:element name="fullyThemedFreeText">
                                          <xs:annotation>
                                            <xs:documentation>Please, refer to the
                                              'fullyThemedFreeText' complexType.</xs:documentation>
                                          </xs:annotation>
                                          <xs:complexType>
                                            <xs:complexContent>
                                              <xs:restriction base="thesu:fullyThemedFreeText">
                                                <xs:sequence>
                                                  <xs:element name="freeText" type="thesu:freeText">
                                                  <xs:annotation>
                                                  <xs:documentation>This is to select a portion of
                                                  the text corresponding to a descendant element of
                                                  a 'PROPOSITION' or "implicit" 'THESIS', as
                                                  annotated in its 'paraphrasis', by typing it in
                                                  the free form of a string. The annotator should
                                                  ensure that the wording corresponds exactly to a
                                                  text span in the pertinent 'paraphrasis'. To
                                                  signal points of discontinuity in the quotation
                                                  use '...'.</xs:documentation>
                                                  </xs:annotation>
                                                  </xs:element>
                                                  <xs:element name="macroThemesGroup"
                                                  type="thesu:macroThemesGroup" minOccurs="0">
                                                  <xs:annotation>
                                                  <xs:documentation>Please, refer to the
                                                  'macroThemesGroup' complexType.</xs:documentation>
                                                  </xs:annotation>
                                                  </xs:element>
                                                  <xs:element name="microThemesGroup" minOccurs="0">
                                                  <xs:annotation>
                                                  <xs:documentation>Please, refer to the
                                                  'microThemesGroup' complexType.</xs:documentation>
                                                  </xs:annotation>
                                                  <xs:complexType>
                                                  <xs:complexContent>
                                                  <xs:restriction base="thesu:microThemesGroup">
                                                  <xs:sequence>
                                                  <xs:element name="microTheme"
                                                  maxOccurs="unbounded">
                                                  <xs:annotation>
                                                  <xs:documentation>Please, refer to the
                                                  'microTheme' complexType.</xs:documentation>
                                                  </xs:annotation>
                                                  <xs:complexType>
                                                  <xs:complexContent>
                                                  <xs:restriction base="thesu:microTheme">
                                                  <xs:sequence>
                                                  <xs:element ref="thesu:conscious" minOccurs="0"/>
                                                  <xs:group ref="thesu:proofBundle"/>
                                                  <xs:element ref="thesu:customElement"
                                                  minOccurs="0" maxOccurs="unbounded"/>
                                                  </xs:sequence>
                                                  <xs:attribute ref="thesu:microThemeTag"
                                                  use="required"/>
                                                  <xs:attribute ref="thesu:focus" default="1"/>
                                                  </xs:restriction>
                                                  </xs:complexContent>
                                                  </xs:complexType>
                                                  </xs:element>
                                                  </xs:sequence>
                                                  <xs:attributeGroup
                                                  ref="thesu:uncertainWithComment"/>
                                                  </xs:restriction>
                                                  </xs:complexContent>
                                                  </xs:complexType>
                                                  </xs:element>
                                                </xs:sequence>
                                                <xs:attribute ref="thesu:comment"/>
                                              </xs:restriction>
                                            </xs:complexContent>
                                          </xs:complexType>
                                        </xs:element>
                                      </xs:choice>
                                      <xs:element name="paraphrasis" type="thesu:paraphrasis"
                                        minOccurs="0">
                                        <xs:annotation>
                                          <xs:documentation>Please, refer to the 'paraphrasis'
                                            complexType.</xs:documentation>
                                        </xs:annotation>
                                      </xs:element>
                                      <xs:element ref="thesu:customElement" minOccurs="0"
                                        maxOccurs="unbounded"/>
                                    </xs:sequence>
                                    <xs:attribute ref="thesu:comparans" default="false"/>
                                    <xs:attribute ref="thesu:implicit"/>
                                    <xs:attributeGroup ref="thesu:uncertainWithComment"/>
                                    <xs:attribute ref="thesu:comparisonRank"/>
                                  </xs:restriction>
                                </xs:complexContent>
                              </xs:complexType>
                            </xs:element>
                            <xs:element name="comparisonDomain" type="thesu:comparisonDomain"
                              minOccurs="0">
                              <xs:annotation>
                                <xs:documentation>Please, refer to the 'comparisonDomain'
                                  complexType</xs:documentation>
                              </xs:annotation>
