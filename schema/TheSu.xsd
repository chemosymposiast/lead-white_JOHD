                                                <xs:attribute ref="thesu:implicit"/>
                                                <xs:attribute ref="thesu:comment"/>
                                              </xs:restriction>
                                            </xs:complexContent>
                                          </xs:complexType>
                                        </xs:element>
                                      </xs:choice>
                                    </xs:sequence>
                                  </xs:restriction>
                                </xs:complexContent>
                              </xs:complexType>
                            </xs:element>
                            <xs:element ref="thesu:customElement" minOccurs="0"
                              maxOccurs="unbounded"/>
                          </xs:sequence>
                          <xs:attribute ref="xml:id"/>
                          <xs:attribute ref="thesu:comment"/>
                        </xs:restriction>
                      </xs:complexContent>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:restriction>
            </xs:complexContent>
          </xs:complexType>
        </xs:element>
        <xs:element name="etiologiesGroup">
          <xs:annotation>
            <xs:documentation>Please, refer to the 'etiologiesGroup' complexType</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:complexContent>
              <xs:restriction base="thesu:etiologiesGroup">
                <xs:sequence>
                  <xs:element name="etiology" minOccurs="0" maxOccurs="unbounded">
                    <xs:annotation>
                      <xs:documentation>Please, refer to the 'etiology'
                        complexType</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:complexContent>
                        <xs:restriction base="thesu:etiology">
                          <xs:sequence>
                            <xs:element ref="thesu:marker" minOccurs="0"/>
                            <xs:element name="etiologyMember" minOccurs="2" maxOccurs="unbounded">
                              <xs:annotation>
                                <xs:documentation>Please, refer to the 'etiologyMember'
                                  complexType</xs:documentation>
                              </xs:annotation>
                              <xs:complexType>
                                <xs:complexContent>
                                  <xs:restriction base="thesu:etiologyMember">
                                    <xs:sequence>
                                      <xs:choice>
                                        <xs:element ref="thesu:textRef"/>
                                        <xs:element ref="thesu:fullyThemedTextRef"/>
                                        <xs:element name="elementRef" type="thesu:elementRef">
                                          <xs:annotation>
                                            <xs:documentation>Please refer to the 'elementRef'
                                              complexType.</xs:documentation>
                                          </xs:annotation>
                                        </xs:element>
                                        <xs:element name="fullyThemedFreeText">
                                          <xs:annotation>
                                            <xs:documentation>Please, refer to the
                                              'fullyThemedFreeText' complexType.</xs:documentation>
                                          </xs:annotation>
                                          <xs:complexType>
                                            <xs:complexContent>
                                              <xs:restriction base="thesu:fullyThemedFreeText">
                                                <xs:sequence>
                                                  <xs:element name="freeText" type="thesu:freeText">
                                                  <xs:annotation>
                                                  <xs:documentation>This is to select a portion of
                                                  the text corresponding to a descendant element of
                                                  a 'PROPOSITION' or "implicit" 'THESIS', as
                                                  annotated in its 'paraphrasis', by typing it in
                                                  the free form of a string. The annotator should
                                                  ensure that the wording corresponds exactly to a
                                                  text span in the pertinent 'paraphrasis'. To
                                                  signal points of discontinuity in the quotation
                                                  use '...'.</xs:documentation>
                                                  </xs:annotation>
                                                  </xs:element>
                                                  <xs:element name="macroThemesGroup"
                                                  type="thesu:macroThemesGroup" minOccurs="0">
                                                  <xs:annotation>
                                                  <xs:documentation>Please, refer to the
                                                  'macroThemesGroup' complexType.</xs:documentation>
                                                  </xs:annotation>
                                                  </xs:element>
                                                  <xs:element name="microThemesGroup" minOccurs="0">
