    <xs:attribute ref="thesu:phasesRef"/>
    <xs:attribute ref="thesu:eventParaphrasis"/>
    <xs:attribute ref="thesu:number"/>
    <xs:attribute ref="thesu:timeUnit"/>
    <xs:attribute ref="thesu:when"/>
    <xs:attribute ref="thesu:approximative"/>
    <xs:attribute ref="thesu:nonNumerical"/>
    <xs:attributeGroup ref="thesu:uncertainWithComment"/>
  </xs:complexType>

  <xs:complexType name="removedObjects">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --></xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="objectRefsGroup" type="thesu:objectRefsGroup">
        <xs:annotation>
          <xs:documentation>Please, refer to the 'objectRefsGroup' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:group ref="thesu:proofBundle"/>
    </xs:sequence>
    <xs:attribute ref="thesu:phasesRef"/>
    <xs:attribute ref="thesu:implicit"/>
    <xs:attributeGroup ref="thesu:uncertainWithComment"/>
  </xs:complexType>

  <xs:complexType name="removedObjectsGroup">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --></xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="removedObjects" type="thesu:removedObjects" maxOccurs="unbounded">
