        <xs:element ref="thesu:metaphorsGroup"/>
        <xs:element ref="thesu:customElement" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="title">
    <xs:annotation>
      <xs:documentation>This is to specify, via '@string' in the free form of a string, a title
        associated with a 'source'. To prove that the annotated title exists for that source, the
        annotator may use 'proof' and refer to textual evidence (i.e. text segments in a digital
        source, corresponding or not corresponding to the source whose URI is referred to in the
        attribute '@ref' of this element's ancestor 'source') of its use as a designator of the
        source. If the title is identified as the source's original title (or as one of its original
        titles), '@original' may be specified as true. If this identification is notably uncertain,
        '@uncertain' may be specified as true. Since it can be open to debate, it is also possible
        to add references to secondary literature, through 'externalRef', 'scholarPro', and
        'scholarContra'. Custom elements can be added through 'customElement'. </xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:group ref="thesu:proofBundle"/>
        <xs:element ref="thesu:customElement" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
      <xs:attribute ref="thesu:string"/>
      <xs:attribute ref="thesu:original"/>
      <xs:attributeGroup ref="thesu:uncertainWithComment"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="uncertainties">
    <xs:annotation>
      <xs:documentation>This is to specify that the text annotated in this element's parent 'text'
        is recognized to be uncertain and potentially corrupt. If it is uncertain due to
        philological reasons (e.g. presence of lacunae), specify '@philological' as "true". The
        existence of variant readings, included in the same 'source' as 'lectio' elements, may be
        taken to corroborate the uncertain character of the text: the annotator can refer to these
        through 'lectioRef'. The text's uncertainty may be commented on in the secondary literature:
        use 'externalRef' to refer to neutral discussions of the matter, 'scholarPro' for texts
        where the uncertainty is argued for or simply accepted, and 'scholarContra' for texts which
        deny it or do not consider it. The annotator may judge that the text is actually not
        uncertain (annotating the 'uncertainties' nonetheless, e.g. merely to consider the
        hypothesis or represent another scholar's point of view): in this case, '@accepted' may be
        specified as "false". Custom elements can be added through
        'customElement'.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice>
        <xs:element ref="thesu:lectioRef" minOccurs="0" maxOccurs="unbounded"/>
        <xs:group ref="thesu:scholarshipBundle"/>
        <xs:element ref="thesu:customElement" minOccurs="0" maxOccurs="unbounded"/>
      </xs:choice>
      <xs:attribute ref="thesu:accepted" default="true"/>
      <xs:attribute ref="thesu:philological" default="false"/>
      <xs:attribute ref="thesu:comment"/>
    </xs:complexType>
  </xs:element>

  <xs:group name="proofBundle">
    <xs:sequence>
      <xs:element ref="thesu:proof" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="externalRef" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="scholarPro" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>This is to cite a passage in the secondary literature that supports the
            annotation in the parent element, i.e. where its core detail is argued for or simply
            accepted. Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="scholarContra" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>This is to cite a passage in the secondary literature that diverges from
            the annotation in the parent element, i.e. where its core detail is denied or simply not
            considered. Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:group name="scholarshipBundle">
    <xs:sequence>
      <xs:element name="externalRef" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="scholarPro" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>This is to cite a passage in the secondary literature that supports the
            annotation of the parent element, i.e. where its core message is argued for or simply
            accepted. Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="scholarContra" type="thesu:externalRef" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>This is to cite a passage in the secondary literature that diverges from
            the annotation of the parent element, i.e. where its core message is denied or simply
            not considered. Please refer to the 'externalRef' complexType.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:attribute name="accepted" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>Generic attribute to specify whether the core detail in the annotation of an
        element is accepted by the annotator or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="agency" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a metaphor component corresponds to words
        denoting or implying an action, and thus their subject's ability to be an agent (e.g.
        "employs", "operation", etc.), or not. This is useful to index animistic
        terminology.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="altered" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a referenced 'PROPOSITION', 'phase', or range of
        'repeatedPhases', although similar in meaning to its connected 'THESIS', 'phase', or range
        of 'repeatedPhases', diverges from it in some details (as e.g. in the proposition
        "discipline and orderliness benefit our intellect" towards the thesis "temperance benefits
        our intellect"; or for the phase "the river flows into the lake" referenced as a
        corresponding or matching phase for "the river flows into the sea"). Alterations in the ways
        of generalization or specification should not be indicated via this attribute, but only via
        the attributes '@generalized' or '@specified' (see their definitions for clarifying
        examples).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="anonymousNickname" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify, in the free form of a string, a nickname with which the
        annotator prefers to refer to the anonymous author or authors of a primary text
        corresponding to a 'source' (e.g. "Pseudo-Aristotle", "Anonymous of Canterbury", etc.), in
        the case the annotated 'authorsGroup' includes no 'author' that has been provided with
        '@rank' = "1".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="approximative" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a quantification, measurement, or indication of a
        time or duration is approximative (e.g. "roughly a spoonful", "just enough", "around three")
        or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="assentValue">
    <xs:annotation>
      <xs:documentation>This is to specify the assent of an individual or group towards the content
        of a 'THESIS' or 'SUPPORT', inasmuch as can be inferred from the full discourse this is
        included in. The annotator may only use the following values: "aff" (affirmative assent) in
        the case the individual or group agrees with it; "neg" (negative assent) in the case the
        individual or group does not agree with it; "att" (attack) in the case the individual or
        group not only does not agree with it, but also refutes it somewhere in the same discourse
        or macrotext. If no value is specified, it is assumed that the speakers' assent is
        indiscernible.</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="yes"/>
        <xs:enumeration value="no"/>
        <xs:enumeration value="att"/>
        <xs:enumeration value=""/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="baseEdition" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a source referenced in a bibliography is the
        "base edition" used for the 'source' or not, i.e. whether the referenced source, being a
        digital edition of a primary text rather than the primary text itself, has been elected by
        the annotator as the base text for the annotation in the 'source' or not. If this attribute
        is specified as "true", the URI referenced in the attribute '@digitalEdition' of the same
        'bibliographyRef' must be identical with the URI referenced in the attribute '@ref' of the
        'bibliographyRef''s ancestor 'source'.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="bibliographicRecords" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@bibliografyRef' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="bibliographyRef" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to a source in a bibliography. The reference must be
        expressed as an href to a bibliographic record in the bibliography authority record
        associated with the TheSu document (i.e. whose URI is referred to in an 'authorityRecord'
        with '@bibliographicRecords' specified as "true").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="biblLocusFree" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to refer precisely to a locus of a referenced work, e.g. page number
        or footnote number, in the free form of a string.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="biblLocusRefFrom" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer, via href, to the URI of a locus indicator in a digital
        source, specifying the beginning of a locus referenced by the annotator, e.g. page number or
        section number.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="biblLocusRefTo" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer, via href, to the URI of a locus indicator in a digital
        source, specifying the ending of a locus referenced by the annotator, e.g. page number or
        section number.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="cause" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an 'etiologyMember' corresponds to one of the
        reported causes in its parent 'etiology' or not; i.e. whether it is the reported cause of
        its sibling 'etiologyMember' elements which are specified to be neither causes nor ends or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="combination" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is produced as a result of the
        combination of other objects annotated in earlier phases within the same 'sequence' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="comment" type="xs:string">
    <xs:annotation>
      <xs:documentation>Generic attribute for comments (typically, to justify or clarify decisions
        in the annotation).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="comparans" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify that a member of an analogy or comparison is assumed in
        its context to be better known than another in the same analogy or comparison, and is thus
        used as a source of features to be projected onto that member, i.e. that it is a "comparans"
        in relation to a "comparandum", or, in Perelman's terminology, a "phoros" in relation to a
        "theme" (e.g., in the analogy "the moon sends us heat like the sun", the member "sun [sends
        us heat]" in relation to the member "the moon sends us heat")</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="comparison" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether or not an analogical structure, rather than
        simply assimilating one or more features of its members (e.g. "the moon sends us heat like
        the sun"), is used to compare them, expressing that in one member they are present with a
        lesser or higher degree than in the others (e.g. "the moon sends us less heat than the
        sun").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="comparisonRank">
    <xs:annotation>
      <xs:documentation>This is to rank a member of a comparison in relation to its siblings,
        according to the lesser or higher degree of the compared features that are attributed to it,
        my means of a number, with "1" representing the highest rank (e.g. in the comparison "the
        moon sends us less heat than the sun" the member "the sun [sends us heat]" may be ranked as
        "1", and "the moon sends us... heat" as "2"). </xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:integer">
        <xs:minInclusive value="1"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="completeEdition" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a source referenced in a bibliography is or
        contains a complete edition of the primary text corresponding to the 'source' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="conjectural" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the variant reading annotated in a 'lectio' is a
        conjectural correction of the text segment referenced in the 'text' of the same 'lectio' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="digitalEdition" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to a digital edition of a source referenced in a
        bibliography. The reference must be expressed as an href to the URI of the file
        corresponding to the digital edition, or, if this is not possible, to its DOI or to its most
        authoritative permalink.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="doubleChecked" type="xs:boolean" default="false">
    <xs:annotation>
      <xs:documentation>General attribute that may be used by the annotator as a reminder to
        double-check the annotated elements.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="durationRange" type="xs:string">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --> This is to specify a duration range,
        using special syntax: - "-10" = up to 10 (maximum) - "10-" = at least 10 (minimum) - "7-10"
        = range from 7 to 10 If no special syntax is used, the value is treated as an exact
        duration.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="end" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an 'etiologyMember' corresponds to one of the
        reported ends in its parent 'etiology' or not; i.e. whether it is the reported end of its
        sibling 'etiologyMember' elements which are specified to be neither causes nor ends or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="entailedAs" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify through a tag the kind of semantic entailment (e.g.
        inclusion or logical subalternity) which is annotated in an 'entailedBy'. The tag must be
        expressed as an href to the URI of an authorized spelling in an authority record associated
        with the TheSu corpus &#8212; i.e. an authority record whose URI is referred to in an
        'authorityRecord' with '@entailmentTags' specified as "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="entailmentTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@entailedAs' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="equivalent" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the referenced similar proposition is logically
        equivalent to this element's ancestor 'PROPOSITION' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="eventParaphrasis" type="xs:string">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --></xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="extended" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the meaning of a referenced 'PROPOSITION',
        'phase', or range of 'repeatedPhases' includes the meaning of its connected 'THESIS',
        'phase', or range of 'repeatedPhases' while also providing additional information
        independent from the latter's message (as e.g. in the proposition "temperance and resolution
        benefit our intellect and well-being by removing superfluous distractions" towards the
        thesis "temperance benefits our intellect"; or for the phase "the river and the sewers flow
        into the sea" referenced as a corresponding or matching phase for "the river flows into the
        sea").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="extracted" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the meaning of a referenced 'PROPOSITION',
        'phase', or range of 'repeatedPhases' is framed as a quotation in the content of its
        connected 'THESIS', 'phase', or range of 'repeatedPhases', in such a way that the former is
        extracted from the quotation framing of the latter (as e.g. in the proposition "temperance
        benefits our intellect" towards the thesis "Aristotle said that temperance benefits our
        intellect"; or for the phase "the river flows into the sea" referenced as a corresponding or
        matching phase for "the fishermen know that the river flows into the
        sea").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="extrinsic" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the content of an annotated 'THESIS', 'SUPPORT',
        or 'externalRef' is neither explicitly present in its corresponding text, nor inferred by
        the annotator to be intended by its speakers or authors, but recognized to be, in the same
        discourse or macrotext, wholly extraneous to the speakers' or authors' intent. Since it can
        be annotated nonetheless for any reason, this attribute is essential to signal the
        arbitrariety of the annotation.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="fictitious" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a formula in the text which limits the full
        commitment of a 'THESIS''s, 'MISC''s, or 'SUPPORT''s speakers towards it qualifies that
        'THESIS', 'MISC', or 'SUPPORT' as fictitious or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="focus">
    <xs:annotation>
      <xs:documentation>This is to specify the degree of centrality of this element's annotated core
        detail to the meaning of the text of its ancestor 'THESIS', 'MISC', or 'PROPOSITION', by
        means of a rank ranging from "1" (most central) to "5" (least central). The degree of
        centrality must be ranked in relation to that of the core details of this element's siblings
        &#8212; whether annotated or merely potential. As a strategy to quantify this centrality in
        absence of elements of comparison, the annotator may try to answer the question: "how much,
        from "5" to "1", would a reader find the present 'THESIS', 'MISC', or 'PROPOSITION' relavant
        to, and informative on, (its speakers' point of view on) the annotated core detail of this
        element?".</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:integer">
        <xs:enumeration value="1"/>
        <xs:enumeration value="2"/>
        <xs:enumeration value="3"/>
        <xs:enumeration value="4"/>
        <xs:enumeration value="5"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="for">
    <xs:annotation>
      <xs:documentation>This is to specify an argumentative support's aim towards the content of its
        target 'THESIS' or 'SUPPORT' elements. The annotator must use one of the following values:
        "acc" if the argument supports the acceptance of its target theses or supports; "rej" if it
        supports their rejection (and is therefore a refutation); or "mix" if it supports both their
        acceptance and rejection at the same time (rather examining or problematizing
        them).</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:NCName">
        <xs:enumeration value="acc"/>
        <xs:enumeration value="rej"/>
        <xs:enumeration value="mix"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="formTag" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify the form in which a support achieves its functions (e.g.
        deductive reasoning, analogy, etc.). The tag must be expressed as an href to the URI of an
        authorized spelling in an authority record associated with the TheSu corpus &#8212; i.e. an
        authority record whose URI is referred to in an 'authorityRecord' with '@formTags' specified
        as "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="formTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@formTag' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="from" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to the beginning of a text segment in a digital source, in
        the form of an href to the URI of a point or segment in the text (e.g. the ID of a
        'tei:seg').</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="generalized" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to indicate whether the referenced 'PROPOSITION', 'phase', or range
        of 'repeatedPhases' has a more general meaning than that of its connected 'THESIS', 'phase',
        or range of 'repeatedPhases', the former potentially encompassing the latter rather than
        matching it directly (e.g., the proposition "certain virtues can benefit our mind" is more
        general than the thesis "temperance benefits our intellect"; or for the phase "the river
        flows into the sea" referenced as a corresponding or matching phase for "the river's
        freshwater encounters the sea's saltwater").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="historyTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@historyTime' and '@historyType' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="historyTimeTag" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify the time in which the events reported by an element that
        has been annotated as "historical", i.e. narrative, in theme take place (e.g. "past",
        "present", etc., with respects to the time of the narrative statements). The tag must be
        expressed as an href to the URI of an authorized spelling in an authority record associated
        with the TheSu corpus &#8212; i.e. an authority record whose URI is referred to in an
        'authorityRecord' with '@historyTags' specified as "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="historyTypeTag" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify what kind of historical information (e.g. concerning
        "actions", "ideas", etc.) is conveyed by an element that has been annotated as "historical",
        i.e. narrative, in theme. The tag must be expressed as an href to the URI of an authorized
        spelling in an authority record associated with the TheSu corpus &#8212; i.e. an authority
        record whose URI is referred to in an 'authorityRecord' with '@historyTags' specified as
        "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="humorous" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a formula in the text which limits the full
        commitment of a 'THESIS''s, 'MISC''s, or 'SUPPORT''s speakers towards it qualifies that
        'THESIS', 'MISC', or 'SUPPORT' as humorous or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="hyperbolic" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a formula in the text which limits the full
        commitment of a 'THESIS''s, 'MISC''s, or 'SUPPORT''s speakers towards it qualifies that
        'THESIS', 'MISC', or 'SUPPORT' as hyperbolic or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="hypothetic" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a formula in the text which limits the full
        commitment of a 'THESIS''s, 'MISC''s, or 'SUPPORT''s speakers towards it qualifies that
        'THESIS', 'MISC', or 'SUPPORT' as hypothetic and provisional or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="implicit" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the semantic content of a number of elements
        including 'THESIS', 'SUPPORT', 'keyword', and several of their descendants, instead of being
        expressed explicitly in the associated text, is inferred by the annotator to be intended by
        the text's speakers in the context of the discourse or macrotext including it, thus being
        conveyed implicitly by other words (e.g.: a rhetorical question, while not being explicitly
        a declarative sentence, might be meant to suggest it to the reader; an intertextual allusion
        might be present implicitly, without a direct citation of the quoted text; a scholar's
        endorsement of an interpretation might be suggested by the tone of their writing even if not
        made explicit; etc.).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="indirectTrad" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the variant reading annotated in a 'lectio'
        occurs in the indirect tradition of the text which corresponds to the 'source' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="ingredient" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is involved in a procedural phase
        within a 'sequence' as an ingredient or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="instrument" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is involved in a procedural phase
        within a 'sequence' as an instrument or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="keywordsInSequence" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to refer to one or more keywords inasmuch as they are referenced in
        a 'keywordsGroup'. To select the keywords, specify the numbers of their corresponding
        'keywordRef' elements in their order of appearance in that 'keywordsGroup', starting with 1,
        and separating each number with a comma (",").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="keywordTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@namely' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="lacuna" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the variant reading annotated in a 'lectio' fills
        a gap in the text which corresponds to the 'source' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="locusRefFrom" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer, via href, to the URI of a locus indicator in a digital
        source, e.g. 'tei:milestone' or HTML 'p', corresponding to the beginning of a cited textual
        passage, section, or any other span of of data.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="locusRefTo" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer, via href, to the URI of a locus indicator in a digital
        source, e.g. 'tei:milestone' or HTML 'p', corresponding to the ending of a cited textual
        passage, section, or any other span of of data.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="macroThemeTag" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify the broad theme (e.g. "historical", "axiological", etc.)
        of a 'THESIS', 'MISC', 'PROPOSITION', or 'phasesGroup' by means of a tag. The tag must be
        expressed as an href to the URI of an authorized spelling in an authority record associated
        with the TheSu document &#8212; i.e. an authority record whose URI is referred to in an
        'authorityRecord' with '@macroThemeTags' specified as "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="macroThemeTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@macroThemeTag' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="measurementType" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify a kind of quantification or measurement (e.g. "count",
        "weight", "length", "temperature", etc.) by means of one or more tags. Each tag must be
        expressed as an href to the URI of an authorized spelling in an authority record &#8212;
        i.e. an authority record whose URI is referred to in an 'authorityRecord' with
        '@objectDetailsTags' specified as "true" &#8212; and must be separated from the others by
        whitespace. </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="measurementUnit" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify a measurement unit (e.g. "gram", "handful", "meter",
        "Celsius degrees", etc.) by means of one or more tags. Each tag must be expressed as an href
        to the URI of an authorized spelling in an authority record &#8212; i.e. an authority record
        whose URI is referred to in an 'authorityRecord' with '@objectDetailsTags' specified as
        "true" &#8212; and must be separated from the others by whitespace. </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="metonymy" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an annotated metaphor is actually a metonymy or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="microThemeTag" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify one of the narrow themes (e.g. "military",
        "psychological", etc.) of a 'THESIS', 'MISC', or 'PROPOSITION' by means of a tag. The tag
        must be expressed as an href to the URI of an authorized spelling in an authority record
        &#8212; i.e. an authority record whose URI is referred to in an 'authorityRecord' with
        '@microThemeTags' specified as "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="microThemeTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@microThemeTag' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="mixture" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is produced as a result of a mixture of
        other objects annotated in earlier phases within the same 'sequence' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="momentInTime" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify an absolute moment in time in the free form of a string,
        following a consistent standard of numerical presentation (e.g. "March 15" may be specified
        as "03-15").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="name" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to the name or group designator of an individual or group
        that is relevant to the parent element, by means of an href to the URI of an authorized
        spelling in an authority record associated with the TheSu corpus &#8212; i.e. an authority
        record whose URI is referred to in an 'authorityRecord' with '@nameTags' specified as
        "true".</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="namely" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to provide one or more paraphrases of an annotated keyword by means
        of one or more tags, each meant for indexing and thus corresponding to a lexeme. Each tag
        must be expressed as an href to the URI of an authorized spelling in an authority record
        &#8212; i.e. an authority record whose URI is referred to in an 'authorityRecord' with
        '@keywordTags' specified as "true" &#8212; and must be separated from the others by
        whitespace.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="nameTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@name' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="nonNumerical" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify a non-numerical quantification, measurement, or
        indication of a time or duration in the free form of a string (e.g. "as required", or "as
        much as they like", "when you prefer", etc.).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="number" type="xs:decimal">
    <xs:annotation>
      <xs:documentation>This is to specify a number, in the form of an integer.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="object" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify which siblings of this 'keywordRef' &#8212;in relation to
        the text of the ancestor 'THESIS', 'MISC', or 'PROPOSITION' of both&#8212; are its syntactic
        objects (e.g. in the case it is a verb). To refer to each of them, specify their number in
        their order of appearance in the same 'keywordsGroup' (i.e. the 'keywordsGroup' which is
        included in this element's ancestor 'THESIS', 'MISC', or 'PROPOSITION'), starting with 1.
        Separate each number with a comma (",").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="objectDetailsTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@measurementUnit' and '@measurementType' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="omittedArgumentationRank" type="thesu:rankType">
    <xs:annotation>
      <xs:documentation>This is to specify the prominence of the argumentation function in an
        omitted SUPPORT element. A value of "1" indicates that argumentation is the most prominent
        function, whereas "4" indicates no particular relevance. </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="omittedContextualisationRank" type="thesu:rankType">
    <xs:annotation>
      <xs:documentation>This is to specify the prominence of the contextualization function in an
        omitted SUPPORT element. A value of "1" indicates that contextualization is the most
        prominent function, whereas "4" indicates no particular relevance.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="omittedExpansionRank" type="thesu:rankType">
    <xs:annotation>
      <xs:documentation>This is to specify the prominence of the expansion function in an omitted
        SUPPORT element. A value of "1" indicates that expansion is the most prominent function,
        whereas "4" indicates no particular relevance.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="omittedExpositionRank" type="thesu:rankType">
    <xs:annotation>
      <xs:documentation>This is to specify the prominence of the exposition function in an omitted
        SUPPORT element. A value of "1" indicates that exposition is the most prominent function,
        whereas "4" indicates no particular relevance.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="opposedAs" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation> This is to specify the kind of semantic opposition (e.g. contrariety or
        contradiction) through a tag. The tag must be expressed as an href to the URI of an
        authorized spelling in an authority record associated with the TheSu corpus &#8212; i.e. an
        authority record whose URI is referred to in an 'authorityRecord' with '@oppositionTags'
        specified as "true". </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="oppositionTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@opposedAs' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="original" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a title annotated for a 'source' is identified by
        the annotator as its original title (or as one of its original titles) or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="partial" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the meaning of a referenced 'PROPOSITION',
        'phase', or range of 'repeatedPhases' corresponds to only a part of the meaning of its
        connected 'THESIS', 'phase', or range of 'repeatedPhases', the latter including additional
        information independent from the former's message (as e.g. in the proposition "temperance
        benefits our intellect" towards the thesis "temperance and resolution benefit our intellect
        and well-being by removing superfluous distractions"; or for the phase "the river flows into
        the sea" referenced as a corresponding or matching phase for "the river and the sewers flow
        into the sea").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="partialRef" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify that only a segment of the variant reading is meant to
        substitute the text of the digital source, as referenced in this element's ancestor 'text'.
        For each word in the 'lectio''s '@variant' &#8212;as delimited by blank space&#8212; that is
        here relevant, specify its number in the succession of the phrase's words, starting with 1.
        Separate each number with a comma (",").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="personhood" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a metaphor component corresponds to words that
        are best understood when their subject is a human or any other intelligent being (e.g.
        "thinks", "dishonest", etc.), or not. This is useful to index anthropomorphic
        terminology.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="phasesRef" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to refer to a range of phases contained in a sequence. The range may
        be either continuous or discontinuous. Since the phases are always annotated as children of
        'phasesGroup' elements, referencing them requires first to indicate their containing
        'phasesGroup' elements, and then, for any indicated 'phasesGroup' containing 'newPhases', to
        indicate their pertinent sub-ranges of 'phase' elements. This second component of the
        reference system is essential when only sub-ranges of phases in the indicated 'phasesGroup'
        elements containing 'newPhases' are relevant to the reference, rather than the indicated
        'phasesGroup' elements as wholes. Note that this nested reference is not possible with
        indicated 'phasesGroup' elements containing 'repeatedPhases': in the case only sub-ranges of
        the phases referenced in 'repeatedPhases' are pertinent to the current reference, it is
        recommended to split those 'repeatedPhases' in multiple 'phasesGroup' elements. To indicate
        the 'phasesGroup' elements, specify their numbers in their order of appearence in the parent
        'sequence', starting with 1 and separating each number with a comma (",") or, to indicate
        ranges, with a hyphen ("-") (e.g. "2,4" refers to the second and the fourth 'phasesGroup' in
        the 'sequence'; "1-3" refers to the range from the first to the third 'phasesGroup' in the
        'sequence', including the second; "1-3,6" refers to the first, second, third, and sixth
        'phasesGroup' in the 'sequence'). To indicate sub-ranges of 'phase' elements in each
        'phasesGroup', insert a dot (".") after the pertinent 'phasesGroup''s number and follow it
        with the 'phase' elements' numbers in their order of appearence in the former's child
        'newPhases', starting with 1 and separating each number with a comma (",") or, to indicate
        ranges, with a hyphen ("-") (e.g. "2.3,4.1-2" refers to the third 'phase' in the 'newPhases'
        child of the second 'phasesGroup' in the 'sequence', followed by the first and second
        'phase' in the 'newPhases' child of the fourth). Note that when this attribute is used in
        'repeatedPhases', discontinuous ranges are not allowed (as any skip in the sequence must be
        indicated in 'repeatedPhases' &#8594; 'exceptedPhases'). Therefore, in the case of
        'repeatedPhases', any number following a comma or hyphen in '@phasesRef' will be assumed as
        irrelevant.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="repetitionsRange" type="xs:string">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --> This is to specify a repetition range,
        using special syntax: - "-10" = up to 10 repetitions (maximum) - "10-" = at least 10
        repetitions (minimum) - "7-10" = range from 7 to 10 repetitions. If no special syntax is
        used, the value is treated as an exact number of repetitions.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="philological" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the text annotated in this element's parent
        'text' is uncertain due to philological reasons (e.g. presence of lacunae) or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="philologicalNotes" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a source referenced in a bibliography is or
        contains a collection of philological notes on the primary text corresponding to the
        'source' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="polarity">
    <xs:annotation>
      <xs:documentation>This is to annotate whether the grammatical polarity of a 'THESIS' or
        'PROPOSITION' element is affirmative or negative, i.e. whether its message is conveyed in an
        affirmative or negative way. Use the value "aff" for affirmative polarity (e.g. "Socrates is
        rational") and "neg" for negative polarity (e.g. "Socrates is not
        irrational").</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="aff"/>
        <xs:enumeration value="neg"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="portion" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is identified as a portion being
        selected or extracted from either itself or other objects annotated in earlier phases within
        the same 'sequence' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="propRef" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to a 'PROPOSITION' element, in the form of an href to its
        ID.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="quantity" type="xs:integer" default="1">
    <xs:annotation>
      <xs:documentation>This is to specify the number of individual statements corresponding to the
        'THESIS'; which is required in the case of aggregate-theses. To calculate the number, the
        annotator must count all the statements in the 'THESIS' that are semantically distinct with
        respects to their autonomous informativity &#8212; e.g. "2" in the case of the
        aggregate-thesis "the sun sends us heat and light", which can be split in "the sun sends us
        heat" + "the sun sends us light" without changes in meaning (contrast e.g. "the sun keeps us
        alive by sending us heat and light", which cannot be split in "the sun keeps us alive by
        sending us heat" + "the sun keeps us alive by sending us light", because according to the
        formulation of the original statement it may be possible that in its meaning neither heat
        neither light are sufficient conditions for the sun to keep us alive, so that separating
        them in two individual statements may alter the original message).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="quoted" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the referenced 'PROPOSITION', 'phase', or range
        of 'repeatedPhases' frames in a quotation or report the meaning of its connected 'THESIS',
        'phase', or range of 'repeatedPhases', rather than matching it directly (e.g. the
        proposition "Aristotle said that temperance benefits our intellect" towards the thesis
        "temperance benefits our intellect"; or for the phase "the fishermen know that the river
        flows into the sea" referenced as a corresponding or matching phase for "the river flows
        into the sea").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="rank" type="thesu:rankType">
    <xs:annotation>
      <xs:documentation>Generic attribute used within annotated SUPPORT elements to specify the
        relative prominence of a function. The annotator must assign a number between "1"
        (indicating the highest prominence) and "4" (indicating no particular relevance), in
        accordance with the ranking scale defined by rankType. </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="reciprocal" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether the targets of a contextualizing support are
        themselves used, by the same speakers, to contextualize the content of the first or not
        &#8212; i.e. whether the contents of multiple, reciprocal, "contextualizing" supports
        including the current are presented in a symmetrical structure in which they are all equally
        rhematic and none thematic with respects to the others or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="ref" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>Generic attribute for hyperlinks, to be expressed in the form of an href to
        a URI.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="role">
    <xs:annotation>
      <xs:documentation>This is to specify the role in a metaphor or metonymy of one of its
        components. The annotator can only use one of the following values: "vehicle" if the
        component corresponds to the metaphorically or metonymically used term; "tenor" if it
        corresponds to the recipient, in the text, of the metaphorically or metonymically conveyed
        idea; and "meaning" if it corresponds to the meaning of the thesis, as it appears
        literalized in a text.</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="vehicle"/>
        <xs:enumeration value="tenor"/>
        <xs:enumeration value="meaning"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="sequenceRef" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to a 'sequence' element, in the form of an href to its
        ID.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="specified" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to indicate whether the referenced 'PROPOSITION', 'phase', or range
        of 'repeatedPhases' has a more specific meaning than that of its connected 'THESIS',
        'phase', or range of 'repeatedPhases', the former being potentially encompassed by the
        latter (e.g., the thesis "temperance benefits our intellect" is more general than the
        proposition "the virtue of temperance usually benefits our intellect by removing superfluous
        distractions"; or for the phase "the river's freshwater encounters the sea's saltwater"
        referenced as a corresponding or matching phase for "the river flows into the
        sea").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="string" type="xs:string">
    <xs:annotation>
      <xs:documentation>Generic attribute for free-form strings of text.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="subject" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify which siblings of this 'keywordRef' &#8212;in relation to
        the text of the ancestor 'THESIS', 'MISC', or 'PROPOSITION' of both&#8212; are its syntactic
        subjects (e.g. in the case it is an adjective). To refer to each of them, specify their
        number in their order of appearance in the same 'keywordsGroup' (i.e. the 'keywordsGroup'
        which is included in this element's ancestor 'THESIS', 'MISC', or 'PROPOSITION'), starting
        with 1. Separate each number with a comma (",").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="subQuantity" type="xs:integer">
    <xs:annotation>
      <xs:documentation>In the case this element has an ancestor aggregate-thesis (i.e. a 'THESIS'
        corresponding to more than one statement and in which its '@quantity' has been given a
        higher value than "1"), and the annotated core detail of this element is not relevant to all
        of the statements in the aggregate, this should be used to specify the precise number of
        statements to which this element is relevant.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="timeUnit" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to specify a time unit (e.g. "UTC calendar day", "lunar month",
        "season", etc.) by means of one or more tags. Each tag must be expressed as an href to the
        URI of an authorized spelling in an authority record &#8212; i.e. an authority record whose
        URI is referred to in an 'authorityRecord' with '@timeUnitTags' specified as "true" &#8212;
        and must be separated from the others by whitespace. </xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="title" type="xs:string">
    <xs:annotation>
      <xs:documentation>Generic attribute to specify the title of a source.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="to" type="xlink:hrefType">
    <xs:annotation>
      <xs:documentation>This is to refer to the end of a text segment in a digital source, in the
        form of an href to the URI of a point or segment in the text (e.g. the ID of a 'tei:seg').
        It is necessary to use this attribute only if the segment is longer than its referenced
        beginning in '@from' (e.g. longer than one word).</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="timeUnitTags" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an authority record contains the authorized
        spellings of the tags in '@timeUnit' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="timingRelation">
    <xs:annotation>
      <xs:documentation>This is to specify whether a time specification refers to a point "after" or
        "before" the referenced event or phase. For example, if durationRange="10" and
        timeUnit="#day", timingRelation="after" means "after 10 days have passed", while
        timingRelation="before" means "after 10 days have passed".</xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="after"/>
        <xs:enumeration value="before"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="transformation" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object is produced as a result of a
        transformation of either itself or other objects annotated in earlier phases within the same
        'sequence' or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="translation" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a source referenced in a bibliography is or
        contains a translation of the primary text corresponding to the 'source' or
        not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="uncertain" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>Generic attribute to specify whether the annotation in an element is notably
        uncertain or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="unspecifiedPlurality" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether an object appears in plural form but with no
        explicit quantification in the text (e.g. "jars" in "lead is placed over vinegar in jars",
        "hammers" in "shape the metal using hammers", "additives" in "additives were incorporated
        into the mixture") or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="value" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>Generic attribute to associate boolean values (i.e. "true" and "false") to
        elements.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="variant" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify the variant reading annotated in a 'lectio', i.e. the
        different spelling that would replace the text segment referenced in the 'text' of the same
        'lectio', if this were accepted.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="weakened" type="xs:boolean">
    <xs:annotation>
      <xs:documentation>This is to specify whether a formula in the text which limits the full
        commitment of a 'THESIS''s, 'MISC''s, or 'SUPPORT''s speakers towards it qualifies that
        'THESIS', 'MISC', or 'SUPPORT' as a weakened claim or section (e.g. "it is likely that...")
        or not.</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="when">
    <xs:annotation>
      <xs:documentation>To be defined soon. <!-- leftover --></xs:documentation>
    </xs:annotation>
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:pattern value="before"/>
        <xs:pattern value="after"/>
        <xs:pattern value="during"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:attribute>

  <xs:attribute name="where" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to specify an object's portion relevant to a specified measure or
        quantitative feature in the free form of a string (e.g. the portion "head" of the object
        "hammer" for the measure "700-gram" in the phase "a heavy-duty hammer with a 700-gram head
        was used to harden the copper bar").</xs:documentation>
    </xs:annotation>
  </xs:attribute>

  <xs:attribute name="wordsInParaphrasis" type="xs:string">
    <xs:annotation>
      <xs:documentation>This is to refer to one or more words in a 'paraphrasis'. To select the
        words, as delimited by blank space, specify their numbers in their order of appearance in
        that 'paraphrasis', starting with 1, and separating each number with a comma
        (",").</xs:documentation>
    </xs:annotation>
  </xs:attribute>


  <xs:attributeGroup name="differencesInCorrespondence">
    <xs:attribute ref="thesu:partial" default="false"/>
    <xs:attribute ref="thesu:extended" default="false"/>
    <xs:attribute ref="thesu:specified" default="false"/>
    <xs:attribute ref="thesu:generalized" default="false"/>
    <xs:attribute ref="thesu:quoted" default="false"/>
    <xs:attribute default="false" ref="thesu:extracted"/>
    <xs:attribute ref="thesu:altered" default="false"/>
  </xs:attributeGroup>

  <xs:attributeGroup name="uncertainWithComment">
    <xs:attribute ref="thesu:uncertain"/>
    <xs:attribute ref="thesu:comment"/>
  </xs:attributeGroup>

</xs:schema>
