"tlg0007_tlg112.T141553" [label="THES", locus="691b", speaker="Plutarchus", text="ὅ τε μόλιβδος ... ὅς γε τριβόμενος ὄξει τὸ ψυκτικώτατον τῶν θανασίμων φαρμάκων ἐξανίησι ψιμύθιον", paraphrasis="When rubbed with vinegar, lead sends forth the most cooling of deadly drugs, i.e., lead white ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T145739" [label="THES", locus="691b", speaker="Plutarchus", text="τὸ ψυκτικώτατον τῶν θανασίμων φαρμάκων ... ψιμύθιον", paraphrasis="Lead white is the most cooling of deadly drugs ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T143932" [label="THES", locus="691b", speaker="Plutarchus", text="ὅ τε μόλιβδος ... ὅς γε τριβόμενος ὄξει τὸ ψυκτικώτατον τῶν θανασίμων φαρμάκων ἐξανίησι", paraphrasis="( Lead can produce the most cooling of deadly drugs ) ", manifestation="implicit", source="tlg0007_tlg112", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S143800" [label="SUPP", text="ὅς γε τριβόμενος ὄξει τὸ ψυκτικώτατον τῶν θανασίμων φαρμάκων ἐξανίησι", locus="691b", speaker="Plutarchus", form="particular-illustration", paraphrasis="\"( Lead can produce the most cooling of deadly drugs )\" JUSTIFIES) \"Lead is among the naturally cold (substances)\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.S201630" [label="SUPP", text="καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες τῆ ... πυκνότητι τὸ ψυχρὸν διὰ βάθους ποιοῦσι ... ὥστʼ", locus="691b", speaker="Plutarchus", form="cause-to-effect", paraphrasis="\"Lead is among the naturally cold (substances)\" + [omitted] JUSTIFIES) \"{It is not strange if} both stone and lead, 'exerting counter-pressure against' {= supporting} the coldness (of the water contained in vessels in which they are plunged), 'tighten' {= intensify} it\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

