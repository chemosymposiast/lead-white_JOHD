"tlg0059_tlg020.T200422" [label=<<b>THESIS</b><br/>           Socrates           <br/>217d<br/><i>When old age has brought (to hair) the (white)<br/>colour, (the hair) becomes like that which is<br/>present, i.e., white by presence of white<br/></i><font point-size="12">"ὅταν δή, ὦ ... παρουσίᾳ λευκαί"</font>>, gephi_label="THES", locus="217d", speaker="Socrates", text="ὅταν δή, ὦ φίλε, τὸ γῆρας αὐταῖς ταὐτὸν τοῦτο χρῶμα ἐπαγάγῃ, τότε ἐγένοντο οἷόνπερ τὸ παρόν, λευκοῦ παρουσίᾳ λευκαί", paraphrasis="When old age has brought (to hair) the (white) colour, (the hair) becomes like that which is present, i.e., white by presence of white ", manifestation="explicit", source="tlg0059_tlg020", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S202031" [label=<<b>SUPPORT</b><br/>          Menexenus           <br/>217e<br/><i>form: affirmation</i><br/><font point-size="12">"πῶς γὰρ οὔ;"</font>>, gephi_label="SUPP", text="πῶς γὰρ οὔ;", locus="217e", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"When old age has brought (to hair) the (white) colour, (the hair) becomes like that which is present, i.e., white by presence of white\" ", manifestation="explicit", fillcolor="#dae8fc", color="#7c9ac7", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

