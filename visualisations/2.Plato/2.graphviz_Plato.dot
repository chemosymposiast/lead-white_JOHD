"tlg0059_tlg020.S183901" [label=<<b>SUPPORT</b><br/>          Menexenus           <br/>217c<br/><i>form: affirmation</i><br/><font point-size="12">"πάνυ γε"</font>>, gephi_label="SUPP", text="πάνυ γε", locus="217c", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed\" ", manifestation="explicit", fillcolor="#dae8fc", color="#7c9ac7", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

