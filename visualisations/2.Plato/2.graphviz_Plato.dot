"tlg0059_tlg020.S182137" [label=<<b>SUPPORT</b><br/>                              <br/>217b<br/><i>form: unspecified</i><br/><font point-size="12">"οὐ γὰρ δή ... γὰρ ὅτι"</font>>, gephi_label="SUPP", text="οὐ γὰρ δή γε κακὸν γεγονὸς ἔτι ἄν τι τοῦ ἀγαθοῦ οὗ ἐπιθυμοῖ καὶ φίλον εἴη · ἀδύνατον γὰρ ἔφαμεν κακὸν ἀγαθῷ φίλον εἶναι. — ἀδύνατον γάρ. — σκέψασθε δὴ ὃ λέγω. λέγω γὰρ ὅτι", locus="217b", speaker="", form="None", paraphrasis="[omitted] CONTEXT) \"Some things are also themselves of such a sort as whatever may be present (in/to them); others are not\" ", manifestation="explicit", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.S182137_func" [label="CONTEXTUALIZES", gephi_label="con", gephi_omitted="false", fontsize="11", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse"];

