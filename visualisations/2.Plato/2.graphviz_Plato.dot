"tlg0059_tlg020.S201741" [label=<<b>SUPPORT</b><br/>           Socrates           <br/>217d<br/><i>form: contrast</i><br/><font point-size="12">"καὶ μὴν παρείη ... ἀλλʼ ὅμως"</font>>, gephi_label="SUPP", text="καὶ μὴν παρείη γʼ ἂν αὐταῖς λευκότης ... ἀλλʼ ὅμως", locus="217d", speaker="Socrates", form="contrast", paraphrasis="\"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ the hair would be in any way whiter than it was before ]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[ the hair would be white ], not[ the hair would be black ]\" CONTRAST) \"When old age has brought (to hair) the (white) colour, (the hair) becomes like that which is present, i.e., white by presence of white\" ", manifestation="explicit", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

