"tlg0059_tlg020.S182137" [label="SUPP", text="οὐ γὰρ δή γε κακὸν γεγονὸς ἔτι ἄν τι τοῦ ἀγαθοῦ οὗ ἐπιθυμοῖ καὶ φίλον εἴη · ἀδύνατον γὰρ ἔφαμεν κακὸν ἀγαθῷ φίλον εἶναι. — ἀδύνατον γάρ. — σκέψασθε δὴ ὃ λέγω. λέγω γὰρ ὅτι", locus="217b", speaker="", form="None", paraphrasis="[omitted] CONTEXT) \"Some things are also themselves of such a sort as whatever may be present (in/to them); others are not\" ", manifestation="explicit", color="wheat", label_color="rosybrown", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.S182137_to_omitted_ELEMENTS_unspecified" [label="ELEM", gephi_omitted="true", gephi_unspecified="true", fontsize="11", color="whitesmoke", label_color="darkgrey", style="dotted,filled,rounded", shape="box", source="tlg0059_tlg020"];

"tlg0059_tlg020.T181551" [label="THES", locus="217c", speaker="Socrates", text="ἔνια μέν, οἷον ἂν ᾖ τὸ παρόν, τοιαῦτά ἐστι καὶ αὐτά, ἔνια δὲ οὔ", paraphrasis="Some things are also themselves of such a sort as whatever may be present (in/to them); others are not ", manifestation="explicit", source="tlg0059_tlg020", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.T182513" [label="THES", locus="217c", speaker="Socrates", text="εἰ ἐθέλοι τις χρώματί τῳ ὁτιοῦν τι ἀλεῖψαι, πάρεστίν που τῷ ἀλειφθέντι τὸ ἐπαλειφθέν", paraphrasis="If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed ", manifestation="explicit", source="tlg0059_tlg020", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S183707" [label="SUPP", text="ὥσπερ εἰ ἐθέλοι τις χρώματί τῳ ὁτιοῦν τι ἀλεῖψαι, πάρεστίν που τῷ ἀλειφθέντι τὸ ἐπαλειφθέν", locus="217c", speaker="Socrates", form="particular-illustration", paraphrasis="\"If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed\" EXPLAINS) \"Some things are also themselves of such a sort as whatever may be present (in/to them); others are not\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.S183901" [label="SUPP", text="πάνυ γε", locus="217c", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.T184302" [label="THES", locus="217c", speaker="Socrates", text="ἆρʼ οὖν καὶ ἔστιν τότε τοιοῦτον τὴν χρόαν τὸ ἀλειφθέν, οἷον τὸ ἐπόν;", paraphrasis="( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it ) ", manifestation="implicit", source="tlg0059_tlg020", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S185420" [label="SUPP", text="οὐ μανθάνω, ἦ δʼ ὅς", locus="217d", speaker="Plato", form="None", paraphrasis="( {text} CONTEXT) \"\"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[they would be white] )\" + \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, they would appear white )\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it \" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[the hair would be in any way whiter than it was before]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[the hair would be white], not[the hair would be black]\" EXPLAINS/justifies) \"( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it )\"\" ) ", manifestation="implicit", color="linen", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.S184918" [label="SUPP", text="ἀλλʼ ὧδε ... εἴ τίς σου ξανθὰς οὔσας τὰς τρίχας ψιμυθίῳ ἀλείψειεν, πότερον τότε λευκαὶ εἶεν ἢ φαίνοιντʼ ἄν; ... καὶ μὴν παρείη γʼ ἂν αὐταῖς λευκότης ... ἀλλʼ ὅμως οὐδέν τι μᾶλλον ἂν εἶεν λευκαί πω, ἀλλὰ παρούσης λευκότητος οὔτε τι λευκαὶ οὔτε μέλαιναί εἰσιν ... ἀλλʼ ὅταν δή, ὦ φίλε, τὸ γῆρας αὐταῖς ταὐτὸν τοῦτο χρῶμα ἐπαγάγῃ, τότε ἐγένοντο οἷόνπερ τὸ παρόν, λευκοῦ παρουσίᾳ λευκαί", locus="217d", speaker="Socrates", form="particular-illustration", paraphrasis="\"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[they would be white] )\" + \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, they would appear white )\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it \" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[the hair would be in any way whiter than it was before]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[the hair would be white], not[the hair would be black]\" EXPLAINS/justifies) \"( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it )\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.T185739" [label="THES", locus="217d", speaker="Socrates", text="εἴ τίς σου ξανθὰς οὔσας τὰς τρίχας ψιμυθίῳ ἀλείψειεν, πότερον τότε λευκαὶ εἶεν ἢ φαίνοιντʼ ἄν;", paraphrasis="( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[they would be white] ) ", manifestation="implicit", source="tlg0059_tlg020", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

