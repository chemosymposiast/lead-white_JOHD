"tlg0059_tlg020.S193431" [label="SUPP", text="φαίνοιντʼ ἄν, ἦ δʼ ὅς", locus="217d", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[they would be white] )\" + \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, they would appear white )\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.T193646" [label="THES", locus="217d", speaker="Socrates", text="εἴ τίς σου ξανθὰς οὔσας τὰς τρίχας ψιμυθίῳ ἀλείψειεν ... καὶ μὴν παρείη γʼ ἂν αὐταῖς λευκότης", paraphrasis="If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it ", manifestation="explicit", source="tlg0059_tlg020", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S194343" [label="SUPP", text="ναί", locus="217d", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

