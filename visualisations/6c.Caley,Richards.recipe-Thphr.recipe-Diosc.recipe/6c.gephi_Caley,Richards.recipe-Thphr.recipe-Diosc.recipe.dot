"tlg0656_tlg001.q213928007" -> "caley_richards_1956.q163717008" [label="is part of, alters", fontcolor="lightslategrey", color="lightslategrey", style="dotted", penwidth=1.25];

"caley_richards_1956.T212135" [label="THES", locus="p. 188", speaker="Caley-Earle-R., Richards-John-F.", text="performing in miniature ··· ······· ···· ········· by Theophrastus. Lead blocks were ········· ···· ····· · five per cent ······ acid solution ·· ·· open vessel, ··· the white crusts that ···· ······ ·· the blocks by corrosion ···· ······· ··· ·· ········· ·· ····· ten days. The product was ... ········ almost immediately, ··· ····· the solution had ····· ··· · few hours it absorbed enough carbon dioxide from the air ·· ····· ··· ···- ·········· ·· · ············ ······ of carbonate. The statements of Theophrastus suggest that, in the process ·· ·········, white lead formed in just this way", paraphrasis="We performed in miniature the process described by Theophrastus to produce lead white: .We supported blocks of lead just above a 5% acetic acid solution in an open vessel, .White crusts formed on the blocks {due to corrosion}, .{Repeatedly}, {at intervals of about 10 days}, we scraped off these crusts, .We identified the obtained product as a lead acetate containing only a small proportion of lead carbonate, .We dissolved this in tap water, .{Almost immediately} we observed a turbidity {due to the formation of basic lead carbonate}, .We let the solution stand for a few hours, .A considerable amount of lead carbonate precipitated {due to the solution having absorbed enough carbon dioxide from the air}, ( .We obtained lead white in the same way as in Theophrastus's process ) ", manifestation="explicit", source="caley_richards_1956", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"caley_richards_1956.q163717001" [label="ph.", phase_number="1", paraphrasis="We supported blocks of lead just above a 5% acetic acid solution in an open vessel ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"caley_richards_1956.q163717002" [label="ph.", phase_number="2", paraphrasis="White crusts formed on the blocks {due to corrosion} ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"caley_richards_1956.q163717003" [label="ph.", phase_number="3", paraphrasis="{Repeatedly}, {at intervals of about 10 days}, we scraped off these crusts ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"caley_richards_1956.q163717004" [label="ph.", phase_number="4", paraphrasis="We identified the obtained product as a lead acetate containing only a small proportion of lead carbonate ", shape="box", color="darkseagreen", label_color="darkgrey", style="rounded,filled"];

"caley_richards_1956.q163717005" [label="ph.", phase_number="5", paraphrasis="We dissolved this in tap water ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"caley_richards_1956.q163717006" [label="ph.", phase_number="6", paraphrasis="{Almost immediately} we observed a turbidity {due to the formation of basic lead carbonate} ", shape="box", color="darkseagreen", label_color="darkgrey", style="rounded,filled"];

"caley_richards_1956.q163717007" [label="ph.", phase_number="7", paraphrasis="We let the solution stand for a few hours ", shape="box", color="darkseagreen", label_color="darkgrey", style="rounded,filled"];

"caley_richards_1956.q163717008" [label="ph.", phase_number="8", paraphrasis="A considerable amount of lead carbonate precipitated {due to the solution having absorbed enough carbon dioxide from the air} ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"caley_richards_1956.q163717009" [label="ph.", phase_number="9", paraphrasis="( We obtained lead white in the same way as in Theophrastus's process ) ", shape="box", color="darkseagreen", label_color="darkgrey", style="rounded,filled"];

"tlg0093_tlg004.P151115" [label="PROP", shape="doubleoctagon", style="rounded,filled", color="ghostwhite", label_color="lightslategrey", paraphrasis="{Theophrastus recipe} To produce lead white: . Place a piece of lead over vinegar in closed jars, .Wait for lead to acquire thickness .Open the jars, .Scrape away from the lead the substance that has formed on its surface, repeating this until you have consumed it completely, .Grind what you have scraped away, .Filter off what you are grinding, .The final precipitate is lead white "];

"tlg0093_tlg004.q151116001" [label="ph.", phase_number="1", paraphrasis="Place a piece of lead over vinegar in closed jars ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116002" [label="ph.", phase_number="2", paraphrasis="Wait for lead to acquire thickness ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116003" [label="ph.", phase_number="3", paraphrasis="Open the jars ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116004" [label="ph.", phase_number="4", paraphrasis="Scrape away from the lead the substance that has formed on its surface, repeating this until you have consumed it completely ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116005" [label="ph.", phase_number="5", paraphrasis="Grind what you have scraped away ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116006" [label="ph.", phase_number="6", paraphrasis="Filter off what you are grinding ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116007" [label="ph.", phase_number="7", paraphrasis="The final precipitate is lead white ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

