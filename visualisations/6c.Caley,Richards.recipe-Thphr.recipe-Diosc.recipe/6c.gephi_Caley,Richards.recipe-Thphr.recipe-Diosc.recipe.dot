digraph G {
"caley_richards_1956" [label="SOURCE", source_id="caley_richards_1956", is_source_node="true", shape="diamond", style="filled", color="thistle", fillcolor="thistle", fontcolor="black", fontsize="16", fontname="bold", width="1.5", height="1.5", penwidth="2", margin="0.2,0.1"];


"tlg0656_tlg001.P213927" [label="PROP", shape="doubleoctagon", style="rounded,filled", color="ghostwhite", label_color="lightslategrey", paraphrasis="{1st Dioscorides recipe} To produce white and effective lead white in the best variety, as well as in worse varieties: .Pour most pungent vinegar into a jar, .Place a piece of lead on a lattice, .Lay the lattice with the lead onto the mouth of the jar, .Above, throw over covers, .Wait until the lead, crumbling down, has strained through the lattice, .Decant away the clean fluid that floats on top of the vinegar, .Pour the remaining viscous fluid into a vessel, .Let the viscous fluid dry under the sun, .Grind the dried substance, .Sift the ground substance, .The substance that is sifted away is the better variety of white and effective lead white, .Grind and sift what remains above the sieve of the solid substance {, repeat, and do it again a third and fourth time}, .The substances that are sifted away at each repeated grinding and sifting are progressively worse varieties of white and effective lead white "];

"tlg0656_tlg001.q213928001" [label="ph.", phase_number="1", paraphrasis="Pour most pungent vinegar into a jar ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928002" [label="ph.", phase_number="2", paraphrasis="Place a piece of lead on a lattice ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928003" [label="ph.", phase_number="3", paraphrasis="Lay the lattice with the lead onto the mouth of the jar ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928004" [label="ph.", phase_number="4", paraphrasis="Above, throw over covers ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928005" [label="ph.", phase_number="5", paraphrasis="Wait until the lead, crumbling down, has strained through the lattice ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928006" [label="ph.", phase_number="6", paraphrasis="Decant away the clean fluid that floats on top of the vinegar ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928007" [label="ph.", phase_number="7", paraphrasis="Pour the remaining viscous fluid into a vessel ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928008" [label="ph.", phase_number="8", paraphrasis="Let the viscous fluid dry under the sun ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928009" [label="ph.", phase_number="9", paraphrasis="Grind the dried substance ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928010" [label="ph.", phase_number="10", paraphrasis="Sift the ground substance ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928011" [label="ph.", phase_number="11", paraphrasis="The substance that is sifted away is the better variety of white and effective lead white ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928012" [label="ph.", phase_number="12", paraphrasis="Grind and sift what remains above the sieve of the solid substance {, repeat, and do it again a third and fourth time} ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0656_tlg001.q213928013" [label="ph.", phase_number="13", paraphrasis="The substances that are sifted away at each repeated grinding and sifting are progressively worse varieties of white and effective lead white ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

