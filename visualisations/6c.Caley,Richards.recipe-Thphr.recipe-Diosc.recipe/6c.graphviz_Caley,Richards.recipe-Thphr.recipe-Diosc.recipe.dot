"tlg0656_tlg001.q213928007" [label=<<b>7</b><br/><i>Pour the remaining viscous<br/>fluid into a vessel<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="Pour the remaining viscous fluid into a vessel ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928008" [label=<<b>8</b><br/><i>Let the viscous fluid dry<br/>under the sun<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="Let the viscous fluid dry under the sun ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

