"caley_richards_1956.q163717004" [label=<<b>4</b><br/><i>We identified the obtained<br/>product as a lead acetate<br/>containing only a small<br/>proportion of lead carbonate<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="We identified the obtained product as a lead acetate containing only a small proportion of lead carbonate ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"caley_richards_1956.q163717005" [label=<<b>5</b><br/><i>We dissolved this in tap water<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="We dissolved this in tap water ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

