"tlg0656_tlg001.q213928003" [label=<<b>3</b><br/><i>Lay the lattice with the lead<br/>onto the mouth of the jar<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="Lay the lattice with the lead onto the mouth of the jar ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

