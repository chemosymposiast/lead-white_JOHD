"tlg0093_tlg004.q151116003" [label=<<b>3</b><br/><i>Open the jars<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="Open the jars ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0093_tlg004.q151116004" [label=<<b>4</b><br/><i>Scrape away from the lead the<br/>substance that has formed on<br/>its surface, repeating this<br/>until you have consumed it<br/>completely<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="Scrape away from the lead the substance that has formed on its surface, repeating this until you have consumed it completely ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0093_tlg004.q151116005" [label=<<b>5</b><br/><i>Grind what you have scraped<br/>away<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="Grind what you have scraped away ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

