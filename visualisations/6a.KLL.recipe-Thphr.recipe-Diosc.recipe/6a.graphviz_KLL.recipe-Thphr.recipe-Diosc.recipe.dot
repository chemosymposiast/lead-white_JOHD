"katsaros_liritzis_laskaris_2010.q131226002" [label=<<b>2</b><br/><i>We placed vinegar on the<br/>bottom of a ceramic vessel<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="We placed vinegar on the bottom of a ceramic vessel ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

