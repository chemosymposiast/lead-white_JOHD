"katsaros_liritzis_laskaris_2010.q131226007" [label=<<b>7</b><br/><i>We removed the skin cover<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="We removed the skin cover ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226008" [label=<<b>8</b><br/><i>We took the brick-shaped lead<br/>out<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="We took the brick-shaped lead out ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226009" [label=<<b>9</b><br/><i>We removed the white powdered<br/>layer (thus formed) on the<br/>surface of the lead by<br/>scratching<br/></i>>, gephi_label="ph.", phase_number="9", paraphrasis="We removed the white powdered layer (thus formed) on the surface of the lead by scratching ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226010" [label=<<b>10</b><br/><i>In a marble mortar, we washed<br/>and ground down to a fine<br/>powder the white powdered<br/>layer using a marble pestle<br/></i>>, gephi_label="ph.", phase_number="10", paraphrasis="In a marble mortar, we washed and ground down to a fine powder the white powdered layer using a marble pestle ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226011" [label=<<b>11</b><br/><i>We waited for it to dry out<br/>under the sun<br/></i>>, gephi_label="ph.", phase_number="11", paraphrasis="We waited for it to dry out under the sun ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226012" [label=<<b>12</b><br/><i>( We obtained the white powder<br/>sample PSI-1 (which is<br/>composed of cerussite and<br/>hydrocerussite, and is<br/>therefore lead white)<br/>following Theophrastus's<br/>recipe (on the preparation of<br/>lead white) )<br/></i>>, gephi_label="ph.", phase_number="12", paraphrasis="( We obtained the white powder sample PSI-1 (which is composed of cerussite and hydrocerussite, and is therefore lead white) following Theophrastus's recipe (on the preparation of lead white) ) ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226013" [label=<<b>13</b><br/><i>We applied it on a prepared<br/>wooden surface with a gypsum<br/>support<br/></i>>, gephi_label="ph.", phase_number="13", paraphrasis="We applied it on a prepared wooden surface with a gypsum support ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

