"katsaros_liritzis_laskaris_2010.T202644" [label=<<b>impl. THESIS</b><br/>Katsaros-T., Liritzis-Ioannis, Laskaris-N.<br/>p. 70<br/><i>( Our combining Theophrastus's recipe for lead<br/>white with Dioscorides's recipe was a<br/>methodologically good choice )<br/></i><font point-size="12">"The report of ... White preparation"</font>>, gephi_label="THES", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="The report of Theophrastus ... The recipe on the preparation of Lead White ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V. Both of the two texts describe a complete method for Lead White preparation", paraphrasis="( Our combining Theophrastus's recipe for lead white with Dioscorides's recipe was a methodologically good choice ) ", manifestation="implicit", source="katsaros_liritzis_laskaris_2010", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"katsaros_liritzis_laskaris_2010.T203426" [label=<<b>THESIS</b><br/>Katsaros-T., Liritzis-Ioannis, Laskaris-N.<br/>p. 70<br/><i>The combination of Theophrastus's recipe for lead<br/>white with Dioscorides's recipe provides a<br/>complete method for the preparation of lead white<br/></i><font point-size="12">"The report of ... White preparation"</font>>, gephi_label="THES", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="The report of Theophrastus ... The recipe on the preparation of Lead White ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V. Both of the two texts describe a complete method for Lead White preparation", paraphrasis="The combination of Theophrastus's recipe for lead white with Dioscorides's recipe provides a complete method for the preparation of lead white ", manifestation="explicit", source="katsaros_liritzis_laskaris_2010", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"katsaros_liritzis_laskaris_2010.S203157" [label=<<b>impl. SUPPORT</b><br/>Katsaros-T., Liritzis-Ioannis, Laskaris-N.<br/>p. 70<br/><i>form: particular-illustration</i><br/><font point-size="12">"Both of the ... White preparation"</font>>, gephi_label="SUPP", text="Both of the two texts describe a complete method for Lead White preparation", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", form="particular-illustration", paraphrasis="( \"Theophrastus's recipe for lead white is incomplete\" + \"The combination of Theophrastus's recipe for lead white with Dioscorides's recipe provides a complete method for the preparation of lead white\" JUSTIFIES) \"( Our combining Theophrastus's recipe for lead white with Dioscorides's recipe was a methodologically good choice )\" ) ", manifestation="implicit", fillcolor="#f5f8fd", color="#949ebf", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="katsaros_liritzis_laskaris_2010"];

