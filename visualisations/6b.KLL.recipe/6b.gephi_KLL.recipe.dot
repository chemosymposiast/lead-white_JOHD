"katsaros_liritzis_laskaris_2010.T202644" [label="THES", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="The report of Theophrastus ... The recipe on the preparation of Lead White ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V. Both of the two texts describe a complete method for Lead White preparation", paraphrasis="( Our combining Theophrastus's recipe for lead white with Dioscorides's recipe was a methodologically good choice ) ", manifestation="implicit", source="katsaros_liritzis_laskaris_2010", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"katsaros_liritzis_laskaris_2010.T203426" [label="THES", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="The report of Theophrastus ... The recipe on the preparation of Lead White ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V ... We have synthe- sised the recipe from the text of Dioscorides Materia Medica V. Both of the two texts describe a complete method for Lead White preparation", paraphrasis="The combination of Theophrastus's recipe for lead white with Dioscorides's recipe provides a complete method for the preparation of lead white ", manifestation="explicit", source="katsaros_liritzis_laskaris_2010", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"katsaros_liritzis_laskaris_2010.S203157" [label="SUPP", text="Both of the two texts describe a complete method for Lead White preparation", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", form="particular-illustration", paraphrasis="( \"Theophrastus's recipe for lead white is incomplete\" + \"The combination of Theophrastus's recipe for lead white with Dioscorides's recipe provides a complete method for the preparation of lead white\" JUSTIFIES) \"( Our combining Theophrastus's recipe for lead white with Dioscorides's recipe was a methodologically good choice )\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="katsaros_liritzis_laskaris_2010"];

"katsaros_liritzis_laskaris_2010.T124253" [label="THES", locus="p. 71", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="Sample PSI- 1 is the reproduced in laboratory white pow- der following Theophrastus ancient recipe On Stones. (ref. On Stones§ 56 above) . Ccommercial metallic lead cut in the shape of a brick approx. 10 cm length by 5 cm width and 2 cm thickness, hanged over within a ceramic ... out. A white powdered layer on its surface was removed by scratch, then washed in a marble mortar and ground down with marble pestle to a fine powder, following a dry out under the sun. Subsequently it was applied on a prepared wooden surface with a gypsum or calcite support", paraphrasis="We reproduced in laboratory the white powder sample PSI-1 (which is composed of cerussite and hydrocerussite, and is therefore lead white) following Theophrastus's recipe (on the preparation of lead white): .We cut commercial metallic lead in the shape of a brick {approx. 10 cm length by 5 cm width by 2 cm thickness}, .We placed vinegar on the bottom of a ceramic vessel, .We hung the brick-shaped piece of lead over the vinegar within the ceramic vessel, .We covered the vessel with a skin {approx. 1 mm (in thickness)} quasi-transparent to air (i.e., such that it breathes), .We placed the vessel under the sun, .We waited {for 10 days}, {at temperatures of average 30 °C and a range of 27-55 degrees}, .We removed the skin cover, .We took the brick-shaped lead out, .We removed the white powdered layer (thus formed) on the surface of the lead by scratching, .In a marble mortar, we washed and ground down to a fine powder the white powdered layer using a marble pestle, .We waited for it to dry out under the sun, ( .We obtained the white powder sample PSI-1 (which is composed of cerussite and hydrocerussite, and is therefore lead white) following Theophrastus's recipe (on the preparation of lead white) ), .We applied it on a prepared wooden surface with a gypsum OR calcite support ", manifestation="explicit", source="katsaros_liritzis_laskaris_2010", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

