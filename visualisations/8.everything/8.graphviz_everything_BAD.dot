"tlg0059_tlg020.T203834" [label=<<b>impl. THESIS</b><br/>           Socrates           <br/>217e<br/><i>( When something is present, not[ that which<br/>possesses (what is present to it) is such as what<br/>is present ] )<br/></i><font point-size="12">"τοῦτο τοίνυν ἐρωτῶ ... μή, οὔ;"</font>>, gephi_label="THES", locus="217e", speaker="Socrates", text="τοῦτο τοίνυν ἐρωτῶ νῦν δή, εἰ ᾧ ἄν τι παρῇ, τοιοῦτον ἔσται τὸ ἔχον οἷον τὸ παρόν · ἢ ἐὰν μὲν κατά τινα τρόπον παρῇ, ἔσται, ἐὰν δὲ μή, οὔ;", paraphrasis="( When something is present, not[ that which possesses (what is present to it) is such as what is present ] ) ", manifestation="implicit", source="tlg0059_tlg020", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S204930" [label=<<b>SUPPORT</b><br/>           Socrates           <br/>217e<br/><i>form: contrast</i><br/><font point-size="12">"εἰ ᾧ ἄν ... · ἢ"</font>>, gephi_label="SUPP", text="εἰ ᾧ ἄν τι παρῇ, τοιοῦτον ἔσται τὸ ἔχον οἷον τὸ παρόν · ἢ", locus="217e", speaker="Socrates", form="contrast", paraphrasis="\"( When something is present, not[ that which possesses (what is present to it) is such as what is present ] )\" (CONTRAST) \"( When something is present, if this is present in a certain way, that which possesses (what is present to it) is such as what is present )\" + \"( When something is present, if this is present not in a certain way, not[ that which possesses (what is present to it) is such as what is present ] )\" ", manifestation="explicit", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

