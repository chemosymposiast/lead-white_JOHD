"tlg0093_tlg004.P151115" [label=<<b>PROPOSITION</b><br/><i>{Theophrastus recipe} To produce lead white: .<br/>Place a piece of lead over vinegar in closed jars,<br/>.Wait for lead to acquire thickness .Open the<br/>jars, .Scrape away from the lead the substance<br/>that has formed on its surface, repeating this<br/>until you have consumed it completely, .Grind what<br/>you have scraped away, .Filter off what you are<br/>grinding, .The final precipitate is lead white<br/></i>>, gephi_label="PROP", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0093_tlg004.P151115_to_tlg0093_tlg004.T151115_1" [label=<MATCHES<br/><i>generalizing</i>>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

