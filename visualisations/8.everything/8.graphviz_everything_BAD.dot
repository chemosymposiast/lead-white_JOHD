"tlg0656_tlg001.T165736" [label=<<b>THESIS</b><br/>     Dioscorides-Pedanius     <br/>5.88.6 (of <i>div</i>)<br/><i>(Lead white) is among the destructive substances<br/></i><font point-size="12">"ἐστι δὲ καὶ τῶν ἀναιρετικῶν"</font>>, gephi_label="THES", locus="5.88.6_div", speaker="Dioscorides-Pedanius", text="ἐστι δὲ καὶ τῶν ἀναιρετικῶν", paraphrasis="(Lead white) is among the destructive substances ", manifestation="explicit", source="tlg0656_tlg001", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

