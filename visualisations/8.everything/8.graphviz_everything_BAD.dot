"tlg0093_tlg004.T183406" [label=<<b>THESIS</b><br/>       pigment-grinders       <br/>55<br/><i>The four colours made by kyanos from itself come<br/>about by technical means<br/></i><font point-size="12">"τὸν μὲν κύανον ... τέχνῃ γίνεται"</font>>, gephi_label="THES", locus="55", speaker="pigment-grinders", text="τὸν μὲν κύανον ἐξ ἑαυτοῦ ποιεῖν χρώματα τέτταρα ... ταῦτά τε δὴ τέχνῃ γίνεται", paraphrasis="The four colours made by kyanos from itself come about by technical means ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S183406" [label=<<b>SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: analogy</i><br/><font point-size="12">"τὸν μὲν κύανον ... καὶ ἔτι"</font>>, gephi_label="SUPP", text="τὸν μὲν κύανον ἐξ ἑαυτοῦ ποιεῖν χρώματα τέτταρα ... ταῦτά τε δὴ τέχνῃ γίνεται καὶ ἔτι", locus="55", speaker="Theophrastus", form="analogy", paraphrasis="\"The four colours made by kyanos from itself come about by technical means\" CONTEXT) \"Lead white comes about by technical means\" ", manifestation="explicit", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S183406_func" [label="CONTEXTUALIZES", gephi_label="con", gephi_omitted="false", fontsize="11", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse"];

"tlg0093_tlg004.S183406_func" -> "tlg0093_tlg004.T170246" [color="#b39c84", style="filled"];

"tlg0093_tlg004.S183406_employed" [label="EMPLOYED IN", gephi_label="in", fontsize="11", fillcolor="#ffe6cc", color="#d79c02", gephi_omitted="false", shape="ellipse", style="filled"];

"tlg0093_tlg004.T183406" -> "tlg0093_tlg004.S183406_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0093_tlg004.T170246" [label=<<b>THESIS</b><br/>         Theophrastus         <br/>55<br/><i>Lead white comes about by technical means<br/></i><font point-size="12">"τέχνῃ γίνεται ... τὸ ψιμύθιον"</font>>, gephi_label="THES", locus="55", speaker="Theophrastus", text="τέχνῃ γίνεται ... τὸ ψιμύθιον", paraphrasis="Lead white comes about by technical means ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S150529" [label=<<b>impl. SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: generalization</i><br/><font point-size="12">"τέχνῃ γίνεται ... τὸ ψιμύθιον. ... γὰρ"</font>>, gephi_label="SUPP", text="τέχνῃ γίνεται ... τὸ ψιμύθιον. ... γὰρ", locus="55", speaker="Theophrastus", form="generalization", paraphrasis="( \"Lead white comes about by technical means\" CONTEXT) \".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white\" ) ", manifestation="implicit", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S150529_func" [label="CONTEXTUALIZES", gephi_label="(con)", gephi_omitted="false", fontsize="11", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse"];

"tlg0093_tlg004.S150529_func" -> "tlg0093_tlg004.T151115" [color="#b3a89a", style="dashed,filled"];

"tlg0093_tlg004.S150529_employed" [label="EMPLOYED IN", gephi_label="in", fontsize="11", fillcolor="#ffe6cc", color="#d79c02", gephi_omitted="false", shape="ellipse", style="filled"];

"tlg0093_tlg004.T170246" -> "tlg0093_tlg004.S150529_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0656_tlg001.P213927" [label=<<b>PROPOSITION</b><br/><i>{1st Dioscorides recipe} To produce white and<br/>effective lead white in the best variety, as well<br/>as in worse varieties: .Pour most pungent vinegar<br/>into a jar, .Place a piece of lead on a lattice,<br/>.Lay the lattice with the lead onto the mouth of<br/>the jar, .Above, throw over covers, .Wait until<br/>the lead, crumbling down, has strained through the<br/>lattice, .Decant away the clean fluid that floats<br/>on top of the vinegar, .Pour the remaining viscous<br/>fluid into a vessel, .Let the viscous fluid dry<br/>under the sun, .Grind the dried substance, .Sift<br/>the ground substance, .The substance that is<br/>sifted away is the better variety of white and<br/>effective lead white, .Grind and sift what remains<br/>above the sieve of the solid substance {, repeat,<br/>and do it again a third and fourth time}, .The<br/>substances that are sifted away at each repeated<br/>grinding and sifting are progressively worse<br/>varieties of white and effective lead white<br/></i>>, gephi_label="PROP", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0656_tlg001.P213927_to_tlg0093_tlg004.T151115_1" [label=<MATCHES<br/><i>generalizing,<br/>specifying,<br/>altering</i>>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0656_tlg001.P213927_to_tlg0656_tlg001.T213927_1" [label=<MATCHES<br/><i>generalizing</i>>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0656_tlg001.P213927_to_tlg0007_tlg112.T141553_1" [label=<MATCHES<br/><i>extending,<br/>being part of,<br/>specifying,<br/>altering</i>>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0656_tlg001.P213927_to_caley_richards_1956.T212135_1" [label=<MATCHES>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

"tlg0656_tlg001.P213927_to_katsaros_liritzis_laskaris_2010.T124253_1" [label=<MATCHES<br/><i>generalizing,<br/>specifying,<br/>altering</i>>, gephi_label="matc", fontsize="11", shape="doubleoctagon", style="rounded,filled", fillcolor="#f9edff", color="#9673a6"];

