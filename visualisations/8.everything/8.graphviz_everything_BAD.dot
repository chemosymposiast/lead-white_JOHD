subgraph source_tlg0656_tlg001 {
label="tlg0656_tlg001";

"tlg0656_tlg001.T202317" [label=<<b>THESIS</b><br/>     Dioscorides-Pedanius     <br/>5.81.1 (of <i>div</i>)<br/><i>Washed lead, as prepared by the second recipe,<br/>when it is being rubbed for sufficient time,<br/>becomes similar to lead white<br/></i><font point-size="12">"σκευάζεται ... ὁ πεπλυμένος ... ψιμυθίῳ ὅμοιον"</font>>, gephi_label="THES", locus="5.81.1_div", speaker="Dioscorides-Pedanius", text="σκευάζεται ... ὁ πεπλυμένος μόλυβδος τὸν τρόπον τοῦτον ... οἱ δὲ ... τὸ μελαινόμενον ... τὸ γὰρ ἐφ ᾿ ἱκανὸν τριβόμενον ... γίνεται ψιμυθίῳ ὅμοιον", paraphrasis="Washed lead, as prepared by the second recipe, when it is being rubbed for sufficient time, becomes similar to lead white ", manifestation="explicit", source="tlg0656_tlg001", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.S203846" [label=<<b>SUPPORT</b><br/>     Dioscorides-Pedanius     <br/>5.81.2 (of <i>div</i>)<br/><i>form: unspecified</i><br/><font point-size="12">"τὸ γὰρ ἐφ ... ψιμυθίῳ ὅμοιον"</font>>, gephi_label="SUPP", text="τὸ γὰρ ἐφ ᾿ ἱκανὸν τριβόμενον ... γίνεται ψιμυθίῳ ὅμοιον", locus="5.81.2_div", speaker="Dioscorides-Pedanius", form="None", paraphrasis="\"Washed lead, as prepared by the second recipe, when it is being rubbed for sufficient time, becomes similar to lead white\" EXPLAINS/justifies) [omitted] ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.S203846_to_omitted_TARGET_THESIS_1" [label=<<b>THESIS</b><br/><i>(omitted)</i>>, gephi_label="THES", gephi_omitted="true", fontsize="11", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", source="tlg0656_tlg001"];

"tlg0656_tlg001.S203846_func" [label="EXPLAINS", gephi_label="exp", gephi_omitted="false", fontsize="11", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse"];

