"katsaros_liritzis_laskaris_2010.T202024" [label=<<b>THESIS</b><br/>Katsaros-T., Liritzis-Ioannis, Laskaris-N.<br/>p. 70<br/><i>Theophrastus's recipe for lead white lacks an<br/>exact description of the jar and its cover<br/></i><font point-size="12">"The report of ... its cover"</font>>, gephi_label="THES", locus="p. 70", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", text="The report of Theophrastus ... The recipe on the preparation of Lead White ... lack of the exact description of the jar and its cover", paraphrasis="Theophrastus's recipe for lead white lacks an exact description of the jar and its cover ", manifestation="explicit", source="katsaros_liritzis_laskaris_2010", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

