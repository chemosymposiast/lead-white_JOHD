"tlg0007_tlg112.S181621" [label=<<b>impl. SUPPORT</b><br/>          Plutarchus          <br/>691a<br/><i>form: general-to-particular</i><br/><font point-size="12">"εἰκός ἐστι τὰ ... διʼ ἀσθένειαν"</font>>, gephi_label="SUPP", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων ... ὑπὸ τοῦ ψυχροῦ · κρατεῖται γὰρ διʼ ἀσθένειαν", locus="691a", speaker="Plutarchus", form="general-to-particular", paraphrasis="( \"( {It is likely that} thinner waters have more weakness )\" JUSTIFIES) \"( As a result of the water (contained in vessels) becoming thinner as caused by (leaden) 'whetstones' and pebbles thinning it, the water becomes weaker )\" ) ", manifestation="implicit", fillcolor="#f5f8fd", color="#949ebf", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

