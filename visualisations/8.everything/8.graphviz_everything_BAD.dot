"tlg0007_tlg112.T181116" [label=<<b>THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>As a result of the water (contained in vessels)<br/>becoming thinner and weaker as caused by (leaden)<br/>'whetstones' and pebbles thinning it, the water is<br/>more effectively dominated by environmental<br/>cooling<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... περιψύξεως κρατεῖσθαι"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον μᾶλλον ὑπὸ περιψύξεως κρατεῖσθαι", paraphrasis="As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling ", manifestation="explicit", source="tlg0007_tlg112", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S144521" [label=<<b>impl. SUPPORT</b><br/>          Plutarchus          <br/>691b<br/><i>form: particular-illustration</i><br/><font point-size="12">"αἱ δʼ ἀκόναι ... περιψύξεως κρατεῖσθαι"</font>>, gephi_label="SUPP", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ, ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον μᾶλλον ὑπὸ περιψύξεως κρατεῖσθαι", locus="691b", speaker="Plutarchus", form="particular-illustration", paraphrasis="( \"As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling\" JUSTIFIES) \"{It is not strange if} both stone and lead, 'exerting counter-pressure against' {= supporting} the coldness (of the water contained in vessels in which they are plunged), 'tighten' {= intensify} it\" ) ", manifestation="implicit", fillcolor="#f5f8fd", color="#949ebf", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

