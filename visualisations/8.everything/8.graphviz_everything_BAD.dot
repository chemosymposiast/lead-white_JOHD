"tlg0656_tlg001.T191034" [label=<<b>extr. THESIS</b><br/>     Dioscorides-Pedanius     <br/>5.88.4 (of <i>div</i>)<br/><i>[[ Lead white can come about white in colour ]]<br/></i><font point-size="12">"θέρους μέντοι ἐργαστέον ... λευκὸν ... γίνεται"</font>>, gephi_label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα · οὕτως γὰρ λευκὸν ... γίνεται", paraphrasis="[[ Lead white can come about white in colour ]] ", manifestation="extrinsic", source="tlg0656_tlg001", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];
}

"tlg0656_tlg001.S140325" [label=<<b>SUPPORT</b><br/>     Dioscorides-Pedanius     <br/>5.88.4 (of <i>div</i>)<br/><i>form: consequence-of-acceptance</i><br/><font point-size="12">"οὕτως γὰρ λευκὸν ... ἐνεργὲς γίνεται"</font>>, gephi_label="SUPP", text="οὕτως γὰρ λευκὸν καὶ ἐνεργὲς γίνεται", locus="5.88.4_div", speaker="Dioscorides-Pedanius", form="consequence-of-acceptance", paraphrasis="\"By accomplishing the operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} in summer, lead white comes about white and effective\" EXPLAINS/justifies) \"The operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} should be accomplished in summer\" ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

