"tlg0059_tlg020.T195224" [label=<<b>THESIS</b><br/>           Socrates           <br/>217d<br/><i>If someone dyed your (i.e., Menexenus's) hair,<br/>which is blond, with lead white, (though)<br/>whiteness being present, not[ the hair would be<br/>white ], not[ the hair would be black ]<br/></i><font point-size="12">"εἴ τίς σου ... μέλαιναί εἰσιν"</font>>, gephi_label="THES", locus="217d", speaker="Socrates", text="εἴ τίς σου ξανθὰς οὔσας τὰς τρίχας ψιμυθίῳ ἀλείψειεν ... παρούσης λευκότητος οὔτε τι λευκαὶ οὔτε μέλαιναί εἰσιν", paraphrasis="If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[ the hair would be white ], not[ the hair would be black ] ", manifestation="explicit", source="tlg0059_tlg020", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S200229" [label=<<b>SUPPORT</b><br/>          Menexenus           <br/>217d<br/><i>form: affirmation</i><br/><font point-size="12">"ἀληθῆ"</font>>, gephi_label="SUPP", text="ἀληθῆ", locus="217d", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ the hair would be in any way whiter than it was before ]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[ the hair would be white ], not[ the hair would be black ]\" ", manifestation="explicit", fillcolor="#dae8fc", color="#7c9ac7", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

