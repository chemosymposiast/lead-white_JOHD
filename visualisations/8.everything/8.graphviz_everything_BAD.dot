subgraph source_tlg0093_tlg004 {
label="tlg0093_tlg004";

"tlg0093_tlg004.S162445" [label=<<b>impl. SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: unspecified</i><br/><font point-size="12">"κύανος ὁ μὲν ... δὲ πεπυρωμένου"</font>>, gephi_label="SUPP", text="κύανος ὁ μὲν αὐτοφυὴς ὁ δὲ σκευαστὸς ὥσπερ ἐν Αἰγύπτῳ. γένη δὲ κυάνου τρία, ὁ αἰγύπτιος καὶ σκύθης καὶ τρίτος ὁ κύπριος. βέλτιστος δʼ ὁ αἰγύπτιος εἰς τὰ ἄκρατα λειώματα ὁ δὲ σκύθης εἰς τὰ ὑδαρέστερα. σκευαστὸς δʼ ὁ αἰγύπτιος. καὶ οἱ γράφοντες τὰ περὶ τοὺς βασιλεῖς καὶ τοῦτο γράφουσι, τίς πρῶτος βασιλεύς ἐποίησε χυτὸν κύανον μιμησάμενος τὸν αὐτοφυῆ, δῶρά τε πέμπεσθαι παρʼ ἄλλων τε καὶ ἐκ Φοινίκης φόρον κυάνου, τοῦ μὲν ἀπύρου τοῦ δὲ πεπυρωμένου", locus="55", speaker="Theophrastus", form="None", paraphrasis="( [omitted] CONTEXT) \"The four colours made by kyanos from itself come about by technical means\" ) ", manifestation="implicit", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S162445_func" [label="CONTEXTUALIZES", gephi_label="(con)", gephi_omitted="false", fontsize="11", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse"];

"tlg0093_tlg004.S162445_func" -> "tlg0093_tlg004.T183406" [color="#b3a89a", style="dashed,filled"];

