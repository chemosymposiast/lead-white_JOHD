"tlg0007_tlg112.T175820" [label=<<b>impl. THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>( As a result of the water (contained in vessels)<br/>becoming thinner as caused by (leaden)<br/>'whetstones' and pebbles thinning it, the water<br/>becomes weaker )<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... ὕδωρ γενόμενον"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον", paraphrasis="( As a result of the water (contained in vessels) becoming thinner as caused by (leaden) 'whetstones' and pebbles thinning it, the water becomes weaker ) ", manifestation="implicit", source="tlg0007_tlg112", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T175820_in_etiology_in_tlg0007_tlg112.T181116_1" [label=<ITS EFFECT<br/>in etiology>, fontsize="11", style="rounded,filled", fillcolor="#e0ffff", color="#008b8b", shape="diamond"];

"tlg0007_tlg112.S182325" [label=<<b>impl. SUPPORT</b><br/>          Plutarchus          <br/>691a<br/><i>form: general-to-particular</i><br/><font point-size="12">"εἰκός ἐστι τὰ ... ὕδωρ γενόμενον"</font>>, gephi_label="SUPP", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων περιψύχεσθαι μᾶλλον ... ὑπὸ τοῦ ψυχροῦ · κρατεῖται γὰρ διʼ ἀσθένειαν ... αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον", locus="691a", speaker="Plutarchus", form="general-to-particular", paraphrasis="( \"{It is likely that} thinner waters are cooled more (intensely) by the surrounding cold\" JUSTIFIES) \"As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling\" ) ", manifestation="implicit", fillcolor="#f5f8fd", color="#949ebf", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

