"tlg0656_tlg001.T135455" [label=<<b>THESIS</b><br/>     Dioscorides-Pedanius     <br/>5.88.4 (of <i>div</i>)<br/><i>By accomplishing the operations described above<br/>{i.e., in the 1st recipe for lead white, in the<br/>2nd recipe for lead white, and in the 1st recipe<br/>for shaping lead white (into lozenges)} in summer,<br/>(lead white) comes about white and effective<br/></i><font point-size="12">"θέρους μέντοι ἐργαστέον ... ἐνεργὲς γίνεται"</font>>, gephi_label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα · οὕτως γὰρ λευκὸν καὶ ἐνεργὲς γίνεται", paraphrasis="By accomplishing the operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} in summer, (lead white) comes about white and effective ", manifestation="explicit", source="tlg0656_tlg001", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T135455_to_tlg0656_tlg001.T191034_1" [label=<by requirement,<br/>ENTAILS>, fontsize="11", style="rounded,filled,dashed", fillcolor="#fcfffd", color="#666666", shape="house"];

