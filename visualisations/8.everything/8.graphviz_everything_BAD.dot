label=<<font color="#82b366">Entailed</font>>
style="dotted";

"tlg0093_tlg004.T180430" [label=<<b>THESIS</b><br/>         Theophrastus         <br/>55<br/><i>Lead the size of a brick placed over vinegar in<br/>(closed) jars acquires thickness in a maximum of<br/>10 days<br/></i><font point-size="12">"τίθεται γὰρ μόλυβδος ... ἡμέραις δέκα"</font>>, gephi_label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα", paraphrasis="Lead the size of a brick placed over vinegar in (closed) jars acquires thickness in a maximum of 10 days ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];
}

"tlg0093_tlg004.S181431" [label=<<b>SUPPORT</b><br/>         Theophrastus         <br/>56<br/><i>form: specification</i><br/><font point-size="12">"λαμβάνει δὲ μάλιστα ... ἡμέραις δέκα"</font>>, gephi_label="SUPP", text="λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα", locus="56", speaker="Theophrastus", form="specification", paraphrasis="\"Lead the size of a brick placed over vinegar in (closed) jars acquires thickness in a maximum of 10 days\" EXPLAINS) \" […] .They wait for lead to acquire thickness […]\" ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S181431_func" [label="EXPLAINS", gephi_label="exp", gephi_omitted="false", fontsize="11", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse"];

"tlg0093_tlg004.S181431_func" -> "tlg0093_tlg004.q151115002" [color="#927b89", style="filled"];

"tlg0093_tlg004.S181431_employed" [label="EMPLOYED IN", gephi_label="in", fontsize="11", fillcolor="#ffe6cc", color="#d79c02", gephi_omitted="false", shape="ellipse", style="filled"];

"tlg0093_tlg004.T180430" -> "tlg0093_tlg004.S181431_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0093_tlg004.S153946" [label=<<b>SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: particular-illustration</i><br/><font point-size="12">"τίθεται γὰρ μόλυβδος ... τὸ ψιμύθιον"</font>>, gephi_label="SUPP", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον", locus="55", speaker="Theophrastus", form="particular-illustration", paraphrasis="\".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white\" EXPLAINS/justifies) \" Lead white comes about by technical means\" ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S153946_func" [label="EXPLAINS", gephi_label="exp", gephi_omitted="false", fontsize="11", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse"];

"tlg0093_tlg004.S153946_func" -> "tlg0093_tlg004.T170246" [color="#927b89", style="filled", dir="back"];

"tlg0093_tlg004.S153946_employed" [label="EMPLOYED IN", gephi_label="in", fontsize="11", fillcolor="#ffe6cc", color="#d79c02", gephi_omitted="false", shape="ellipse", style="filled"];

"tlg0093_tlg004.T151115" -> "tlg0093_tlg004.S153946_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0093_tlg004.T154708" [label=<<b>THESIS</b><br/>         Theophrastus         <br/>55<br/><i>Copper rust comes about by a (technical) process<br/>very similar to lead white's<br/></i><font point-size="12">"τίθεται γὰρ μόλυβδος ... ἰὸς γίνεται"</font>>, gephi_label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον. παραπλησίως δὲ καὶ ὁ ἰὸς γίνεται", paraphrasis="Copper rust comes about by a (technical) process very similar to lead white's ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S160706" [label=<<b>impl. SUPPORT</b><br/>         Theophrastus         <br/>56<br/><i>form: generalization</i><br/><font point-size="12">"παραπλησίως δὲ καὶ ... γίνεται ·"</font>>, gephi_label="SUPP", text="παραπλησίως δὲ καὶ ὁ ἰὸς γίνεται ·", locus="56", speaker="Theophrastus", form="generalization", paraphrasis="( \"Copper rust comes about by a (technical) process very similar to lead white's\" CONTEXT) [omitted] ) ", manifestation="implicit", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

