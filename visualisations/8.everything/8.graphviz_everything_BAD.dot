"tlg0059_tlg020.T181551" [label=<<b>THESIS</b><br/>           Socrates           <br/>217c<br/><i>Some things are also themselves of such a sort as<br/>whatever may be present (in/to them); others are<br/>not<br/></i><font point-size="12">"ἔνια μέν, οἷον ... δὲ οὔ"</font>>, gephi_label="THES", locus="217c", speaker="Socrates", text="ἔνια μέν, οἷον ἂν ᾖ τὸ παρόν, τοιαῦτά ἐστι καὶ αὐτά, ἔνια δὲ οὔ", paraphrasis="Some things are also themselves of such a sort as whatever may be present (in/to them); others are not ", manifestation="explicit", source="tlg0059_tlg020", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.T182513" [label=<<b>THESIS</b><br/>           Socrates           <br/>217c<br/><i>If someone dyes anything a certain colour, that<br/>which is smeared on is present to the thing that<br/>has been dyed<br/></i><font point-size="12">"εἰ ἐθέλοι τις ... τὸ ἐπαλειφθέν"</font>>, gephi_label="THES", locus="217c", speaker="Socrates", text="εἰ ἐθέλοι τις χρώματί τῳ ὁτιοῦν τι ἀλεῖψαι, πάρεστίν που τῷ ἀλειφθέντι τὸ ἐπαλειφθέν", paraphrasis="If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed ", manifestation="explicit", source="tlg0059_tlg020", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.T182513_in_etiology_in_tlg0059_tlg020.T184302_1" [label=<CORRELATED<br/>in etiology>, fontsize="11", style="rounded,filled,dashed", fillcolor="#e0ffff", color="#008b8b", shape="diamond"];

"tlg0059_tlg020.S183707" [label=<<b>SUPPORT</b><br/>           Socrates           <br/>217c<br/><i>form: particular-illustration</i><br/><font point-size="12">"ὥσπερ εἰ ἐθέλοι ... τὸ ἐπαλειφθέν"</font>>, gephi_label="SUPP", text="ὥσπερ εἰ ἐθέλοι τις χρώματί τῳ ὁτιοῦν τι ἀλεῖψαι, πάρεστίν που τῷ ἀλειφθέντι τὸ ἐπαλειφθέν", locus="217c", speaker="Socrates", form="particular-illustration", paraphrasis="\"If someone dyes anything a certain colour, that which is smeared on is present to the thing that has been dyed\" EXPLAINS) \"Some things are also themselves of such a sort as whatever may be present (in/to them); others are not\" ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

