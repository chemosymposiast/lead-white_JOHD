"tlg0007_tlg112.T152959" [label=<<b>THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>(Leaden) 'whetstones' and pebbles thin the water<br/>(contained in the vessels in which they are<br/>plunged) by gathering and drawing down from it the<br/>turbid and earthy parts that have become mixed<br/>with it<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... ἀπʼ αὐτοῦ"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ", paraphrasis="(Leaden) 'whetstones' and pebbles thin the water (contained in the vessels in which they are plunged) by gathering and drawing down from it the turbid and earthy parts that have become mixed with it ", manifestation="explicit", source="tlg0007_tlg112", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T184712" [label=<<b>THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>(Leaden) 'whetstones' and pebbles gather and draw<br/>down from the water (contained in the vessels in<br/>which they are plunged) the turbid and earthy<br/>parts that have become mixed with it<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... ἀπʼ αὐτοῦ"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ", paraphrasis="(Leaden) 'whetstones' and pebbles gather and draw down from the water (contained in the vessels in which they are plunged) the turbid and earthy parts that have become mixed with it ", manifestation="explicit", source="tlg0007_tlg112", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

