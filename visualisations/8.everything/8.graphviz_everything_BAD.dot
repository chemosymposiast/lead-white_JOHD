"tlg0059_tlg020.T210154" [label=<<b>impl. THESIS</b><br/>           Socrates           <br/>217e<br/><i>There are times in which, when bad is present,<br/>what is neither bad nor good is not yet bad, and<br/>others in which this has already become bad<br/></i><font point-size="12">"τὸ μήτε κακὸν ... τοιοῦτον γέγονεν"</font>>, gephi_label="THES", locus="217e", speaker="Socrates", text="τὸ μήτε κακὸν ἄρα μήτʼ ἀγαθὸν ἐνίοτε κακοῦ παρόντος οὔπω κακόν ἐστιν, ἔστιν δʼ ὅτε ἤδη τὸ τοιοῦτον γέγονεν", paraphrasis="There are times in which, when bad is present, what is neither bad nor good is not yet bad, and others in which this has already become bad ", manifestation="implicit", source="tlg0059_tlg020", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S211034" [label=<<b>SUPPORT</b><br/>          Menexenus           <br/>217e<br/><i>form: affirmation</i><br/><font point-size="12">"πάνυ γε"</font>>, gephi_label="SUPP", text="πάνυ γε", locus="217e", speaker="Menexenus", form="affirmation", paraphrasis="{text} AFFIRMS) \"There are times in which, when bad is present, what is neither bad nor good is not yet bad, and others in which this has already become bad\" ", manifestation="explicit", fillcolor="#dae8fc", color="#7c9ac7", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

