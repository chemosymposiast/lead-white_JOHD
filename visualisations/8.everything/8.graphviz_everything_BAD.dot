"caley_richards_1956.S212203" [label=<<b>impl. SUPPORT</b><br/>Caley-Earle-R., Richards-John-F.<br/>p. 188<br/><i>form: unspecified</i><br/><font point-size="12">"What has been ... an- cients"</font>>, gephi_label="SUPP", text="What has been ···- ······ ·········· ·· ···· the air itself ··· ··· ····· ···· ·· ··· ······· ·········· ········ ······ ······ ······· ·· ······· ····· ···· ········· ·· ··· ·····- ····· ········· ···· ·· ··· an- cients", locus="p. 188", speaker="Caley-Earle-R., Richards-John-F.", form="None", paraphrasis="( \"In the small-scale processes used by the ancients to produce basic lead carbonate, air and the water used in the washing operations provided enough carbon dioxide to obtain this product\" REFUTES) [omitted] ) ", manifestation="implicit", fillcolor="#fdf6f6", color="#a89794", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="caley_richards_1956"];

