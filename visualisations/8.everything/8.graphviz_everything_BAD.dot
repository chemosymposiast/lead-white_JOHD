"tlg0059_tlg020.T184302" [label=<<b>impl. THESIS</b><br/>           Socrates           <br/>217c<br/><i>( If someone dyes anything a certain colour, that<br/>which is smeared on being thus present to the<br/>thing that has been dyed, the colour of the thing<br/>that has been dyed is not the same as that of what<br/>is present to it )<br/></i><font point-size="12">"ἆρʼ οὖν καὶ ... τὸ ἐπόν;"</font>>, gephi_label="THES", locus="217c", speaker="Socrates", text="ἆρʼ οὖν καὶ ἔστιν τότε τοιοῦτον τὴν χρόαν τὸ ἀλειφθέν, οἷον τὸ ἐπόν;", paraphrasis="( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it ) ", manifestation="implicit", source="tlg0059_tlg020", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0059_tlg020.S185420" [label=<<b>impl. SUPPORT</b><br/>            Plato             <br/>217d<br/><i>form: unspecified</i><br/><font point-size="12">"οὐ μανθάνω, ἦ δʼ ὅς"</font>>, gephi_label="SUPP", text="οὐ μανθάνω, ἦ δʼ ὅς", locus="217d", speaker="Plato", form="None", paraphrasis="( {text} CONTEXT) \"\"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ they would be white ] )\" + \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, they would appear white )\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it \" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ the hair would be in any way whiter than it was before ]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[ the hair would be white ], not[ the hair would be black ]\" EXPLAINS/justifies) \"( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it )\"\" ) ", manifestation="implicit", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

"tlg0059_tlg020.S185420_func" [label="CONTEXTUALIZES", gephi_label="(con)", gephi_omitted="false", fontsize="11", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse"];

"tlg0059_tlg020.S185420_func" -> "tlg0059_tlg020.S184918" [color="#b3a89a", style="dashed,filled"];

"tlg0059_tlg020.S184918" [label=<<b>SUPPORT</b><br/>           Socrates           <br/>217d<br/><i>form: particular-illustration</i><br/><font point-size="12">"ἀλλʼ ὧδε ... εἴ ... παρουσίᾳ λευκαί"</font>>, gephi_label="SUPP", text="ἀλλʼ ὧδε ... εἴ τίς σου ξανθὰς οὔσας τὰς τρίχας ψιμυθίῳ ἀλείψειεν, πότερον τότε λευκαὶ εἶεν ἢ φαίνοιντʼ ἄν; ... καὶ μὴν παρείη γʼ ἂν αὐταῖς λευκότης ... ἀλλʼ ὅμως οὐδέν τι μᾶλλον ἂν εἶεν λευκαί πω, ἀλλὰ παρούσης λευκότητος οὔτε τι λευκαὶ οὔτε μέλαιναί εἰσιν ... ἀλλʼ ὅταν δή, ὦ φίλε, τὸ γῆρας αὐταῖς ταὐτὸν τοῦτο χρῶμα ἐπαγάγῃ, τότε ἐγένοντο οἷόνπερ τὸ παρόν, λευκοῦ παρουσίᾳ λευκαί", locus="217d", speaker="Socrates", form="particular-illustration", paraphrasis="\"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ they would be white ] )\" + \"( If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, they would appear white )\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, whiteness would be present to it \" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, not[ the hair would be in any way whiter than it was before ]\" + \"If someone dyed your (i.e., Menexenus's) hair, which is blond, with lead white, (though) whiteness being present, not[ the hair would be white ], not[ the hair would be black ]\" EXPLAINS/justifies) \"( If someone dyes anything a certain colour, that which is smeared on being thus present to the thing that has been dyed, the colour of the thing that has been dyed is not the same as that of what is present to it )\" ", manifestation="explicit", fillcolor="#edffc4", color="#927b89", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0059_tlg020"];

