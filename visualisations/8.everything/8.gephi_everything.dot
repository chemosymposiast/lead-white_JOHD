"katsaros_liritzis_laskaris_2010.S190032" [label="SUPP", text="Figure 8: Reconstruction of the apparatus according to Theophrastus in his text“ On Stones” for the preparation of the psimythion(lead white) .", locus="p. 77", speaker="Katsaros-T., Liritzis-Ioannis, Laskaris-N.", form="visualization", paraphrasis="{text} EXPLAINS) \"[…] .We hung the brick-shaped piece of lead over the vinegar within the ceramic vessel, .We covered the vessel with a skin {approx. 1 mm (in thickness)} quasi-transparent to air (i.e., such that it breathes) […]\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="katsaros_liritzis_laskaris_2010"];

