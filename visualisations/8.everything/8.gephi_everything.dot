"tlg0093_tlg004.T180430" [label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα", paraphrasis="Lead the size of a brick placed over vinegar in (closed) jars acquires thickness in a maximum of 10 days ", manifestation="explicit", source="tlg0093_tlg004", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S181431" [label="SUPP", text="λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα", locus="56", speaker="Theophrastus", form="specification", paraphrasis="\"Lead the size of a brick placed over vinegar in (closed) jars acquires thickness in a maximum of 10 days\" EXPLAINS) \" […] .They wait for lead to acquire thickness […]\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S153946" [label="SUPP", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον", locus="55", speaker="Theophrastus", form="particular-illustration", paraphrasis="\".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white\" EXPLAINS/justifies) \" Lead white comes about by technical means\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.T154708" [label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον. παραπλησίως δὲ καὶ ὁ ἰὸς γίνεται", paraphrasis="Copper rust comes about by a (technical) process very similar to lead white's ", manifestation="explicit", source="tlg0093_tlg004", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S160706" [label="SUPP", text="παραπλησίως δὲ καὶ ὁ ἰὸς γίνεται -", locus="56", speaker="Theophrastus", form="generalization", paraphrasis="( \"Copper rust comes about by a (technical) process very similar to lead white's\" CONTEXT) [omitted] ) ", manifestation="implicit", color="linen", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S160706_to_omitted_TARGET_THESIS_1" [label="THES", gephi_omitted="true", fontsize="11", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", source="tlg0093_tlg004"];

"tlg0656_tlg001.T202317" [label="THES", locus="5.81.1_div", speaker="Dioscorides-Pedanius", text="σκευάζεται ... ὁ πεπλυμένος μόλυβδος τὸν τρόπον τοῦτον ... οἱ δὲ ... τὸ μελαινόμενον ... τὸ γὰρ ἐφ ᾿ ἱκανὸν τριβόμενον ... γίνεται ψιμυθίῳ ὅμοιον", paraphrasis="Washed lead, as prepared by the second recipe, when it is being rubbed for sufficient time, becomes similar to lead white ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.S203846" [label="SUPP", text="τὸ γὰρ ἐφ ᾿ ἱκανὸν τριβόμενον ... γίνεται ψιμυθίῳ ὅμοιον", locus="5.81.2_div", speaker="Dioscorides-Pedanius", form="None", paraphrasis="\"Washed lead, as prepared by the second recipe, when it is being rubbed for sufficient time, becomes similar to lead white\" EXPLAINS/justifies) [omitted] ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.S203846_to_omitted_TARGET_THESIS_1" [label="THES", gephi_omitted="true", fontsize="11", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", source="tlg0656_tlg001"];

"tlg0656_tlg001.T211310" [label="THES", locus="5.82_div", speaker="Dioscorides-Pedanius", text="σκωρία δὲ μολύβδου ἐστὶν ἀρίστη ἡ ψιμυθιοφανής, πυκνὴ δὲ καὶ δύσθραυστος, μηδὲν ἔχουσα μολυβδῶδες, μηλινοειδὴς δὲ τῷ χρώματι καὶ ὑαλίζουσα", paraphrasis="The best lead dross is that which looks like lead white, is dense and difficult to break, contains nothing leaden, is quince-like in colour, and glassy ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T213927" [label="THES", locus="5.88.1_div", speaker="Dioscorides-Pedanius", text="ψιμύθιον δὲ γίνεται οὕτως - εἰς πιθάκνην πλατύστομον ἢ κεραμεᾶν γάστραν ἐγχέας δριμύτατον ὄξος ἀπέρεισαι μολυβδίνην πλίνθον ἐπὶ τὸ στόμα τοῦ κεραμίου, προυποκειμένου καλαμίνου ῥίπου, ἄνωθέν τε αὐτῆς ἐπίρριψον σκεπάσματα πρὸς τὸ μὴ διαπνεῖσθαι τὸ ὀξος · ὡς δʼ ἂν καταρρυεῖσα διαπέσῃ, τὸ μὲν ἐπαιωρούμενον καὶ καθαρὸν ὑγρὸν ἀπηθητέον, τὸ δὲ γλοιῶδες εἰς ἀγγεῖον ἐγχυτέον καὶ ξηραντέον ἐν ἡλίῳ. εἶτα ἀλεστέον ἐν χειρομυλίῳ ἢ λεαντέον ἄλλως καὶ σηστέον, 2 καὶ μετὰ ταῦτα τὸ λοιπὸν τοῦ στερεμνίου λεπτοποιητέον καὶ σηστέον, ἐναλλάξ τε τὰ αὐτὰ καὶ τρίτον καὶ τέταρτον ποιητέον", paraphrasis="In order for (white and effective) lead white to come about in the best variety - to be used for ophthalmological properties - as well as in worse varieties, .(In summer, ) pour most pungent vinegar into a broad-mouthed jar OR pot-bellied clay jar, .Place a leaden brick on a lattice of reeds, .Lay the lattice of reeds with the leaden brick onto the mouth of the pot, .Above, throw over covers to prevent vinegar from evaporating, .Wait until (the leaden brick), crumbling down, has strained through (the lattice), .Decant away the clean fluid that floats on top (of the vinegar after the leaden brick has crumbled down in it), .Pour the (remaining) viscous fluid into a vessel, .Let the viscous fluid dry under the sun, .Smooth the dried substance with a hand-mill OR in any way, .Sift the ground substance, .The substance that is sifted away is the better variety of (white and effective) lead white, that should be picked also for ophthalmological properties, .Thin (with a hand-mill OR in any way) and sift what remains (above the sieve) of the solid substance {, repeat, and do it again a third and fourth time}, .The substances that are sifted away at each repeated thinning and sifting are progressively worse varieties of (white and effective) lead white ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.q213927001" [label="ph.", phase_number="1", paraphrasis="(In summer, ) pour most pungent vinegar into a broad-mouthed jar ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927002" [label="ph.", phase_number="2", paraphrasis="Place a leaden brick on a lattice of reeds ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927003" [label="ph.", phase_number="3", paraphrasis="Lay the lattice of reeds with the leaden brick onto the mouth of the pot (i.e., of the broad-mouthed jar) ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927004" [label="ph.", phase_number="4", paraphrasis="Above, throw over covers (to prevent vinegar from evaporating) ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927005" [label="ph.", phase_number="5", paraphrasis="Wait until (the leaden brick), crumbling down, has strained through (the lattice) ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927006" [label="ph.", phase_number="6", paraphrasis="Decant away the clean fluid that floats on top (of the vinegar after the leaden brick has crumbled down in it) ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927007" [label="ph.", phase_number="7", paraphrasis="Pour the (remaining) viscous fluid into a vessel ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927008" [label="ph.", phase_number="8", paraphrasis="Let the viscous fluid dry under the sun ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927009" [label="ph.", phase_number="9", paraphrasis="Grind the dried substance with a hand-mill ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927010" [label="ph.", phase_number="10", paraphrasis="Sift the ground substance ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927011" [label="ph.", phase_number="11", paraphrasis="The substance that is sifted away is the better variety of (white and effective) lead white, that should be picked also for ophthalmological properties ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927012" [label="ph.", phase_number="12", paraphrasis="Thin (with a hand-mill) and sift what remains (above the sieve) of the solid substance {, repeat, and do it again a third and fourth time} ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q213927013" [label="ph.", phase_number="13", paraphrasis="The substances that are sifted away at each repeated thinning and sifting are progressively worse varieties of (white and effective) lead white ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.T175521" [label="THES", locus="5.88.1_div", speaker="Dioscorides-Pedanius", text="ψιμύθιον ... ἄμεινον ... τὸ πρῶτον ἀποσησθέν, ὃ καὶ εἰς τὰς ὀφθαλμικὰς παραλημπτέον δυνάμεις", paraphrasis="The better variety, first to be sifted away, of (white and effective) lead white should be picked also for ophthalmological properties ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T165902" [label="THES", locus="5.88.3_div", speaker="Dioscorides-Pedanius", text="τινὲς δὲ κατὰ μέσον τὸ ἀγγεῖον κατερείσαντες 3 ξύλον, τὸν ῥῖπον ἐπιτιθέασιν ὡς μὴ ψαύειν τοῦ ὄξους, τὸ δὲ στόμα αὐτοῦ πωμάσαντες καὶ περιχρίσαντες ἐῶσι καὶ ... δι ὰ ι ´ ἡμερῶν ἀφαιρούμενοι τὸ πῶμα ἐπισκοποῦνται - ὅταν δὲ διαλυθῇ, τὰ ἄλλα ποιοῦσιν ὁμοίως τοῖς προειρημένοις", paraphrasis="(In order for (white and effective) lead white to come about (in the best variety - to be used for ophthalmological properties - as well as in worse varieties),) Some (. (In summer, ) pour most pungent vinegar into a vessel {as per phase 1 of the 1st recipe for lead white} ), (. They place a leaden brick on a lattice (of reeds) {as per phase 2 of the 1st recipe for lead white} ), .They lay a piece of wood in the middle of the vessel, .They place the lattice (with the leaden brick) on top of the piece of wood in such a way that the former does not touch the vinegar, .They close the mouth of the vessel (with a lid), .They smear it all around (in such a way as to seal it), .They leave the thus closed vessel alone (under the sun) {for 10 days}, .Removing the lid, they look into the vessel, .{When the (leaden brick) has dissolved}, they do the same as in {phases 6 to 13 of the 1st recipe for lead white} ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T185635" [label="THES", locus="5.88.3_div", speaker="Dioscorides-Pedanius", text="εἰ δὲ ἀναπλάσαι θέλοι τις αὐτό, ὄξει δριμεῖ φυρατέον καὶ οὕτως ἀναπλαστέον καὶ ξηραντέον ἐν ἡλίῳ", paraphrasis="To shape ((white and effective) lead white) (into lozenges), .(In summer,) knead (the lead white) with pungent vinegar, .Make it into shapes, .Leave it to dry under the sun ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.q190856001" [label="ph.", phase_number="1", paraphrasis="(In summer,) knead (the lead white) with pungent vinegar ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q190856002" [label="ph.", phase_number="2", paraphrasis="Make it into shapes ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q190856003" [label="ph.", phase_number="3", paraphrasis="Leave it to dry under the sun ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.q190856004" [label="ph.", phase_number="4", paraphrasis="( You have (white and effective) lead white shaped (into lozenges) ) ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0656_tlg001.T214145" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα", paraphrasis="The operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} should be accomplished in summer ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.S122317" [label="SUPP", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα", locus="5.88.4_div", speaker="Dioscorides-Pedanius", form="specification", paraphrasis="\"The operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} should be accomplished in summer\" EXPLAINS) {1st recipe for lead white}, {2nd recipe for lead white}, {recipe for 1st recipe lead white (into lozenges)} ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.S193438" [label="SUPP", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα", locus="5.88.4_div", speaker="Dioscorides-Pedanius", form="contrast", paraphrasis="( \"The operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} should be accomplished in summer\" CONTEXT) {3rd and 4th recipe for lead white}, {2nd recipe for shaping lead white (into lozenges)} ) ", manifestation="implicit", color="linen", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.T135455" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα - οὕτως γὰρ λευκὸν καὶ ἐνεργὲς γίνεται", paraphrasis="By accomplishing the operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} in summer, (lead white) comes about white and effective ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T191034" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα - οὕτως γὰρ λευκὸν ... γίνεται", paraphrasis="[[Lead white can come about white in colour]] ", manifestation="extrinsic", source="tlg0656_tlg001", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.S140325" [label="SUPP", text="οὕτως γὰρ λευκὸν καὶ ἐνεργὲς γίνεται", locus="5.88.4_div", speaker="Dioscorides-Pedanius", form="consequence-of-acceptance", paraphrasis="\"By accomplishing the operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} in summer, lead white comes about white and effective\" EXPLAINS/justifies) \"The operations described above {i.e., in the 1st recipe for lead white, in the 2nd recipe for lead white, and in the 1st recipe for shaping lead white (into lozenges)} should be accomplished in summer\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.T193924" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="σκευάζεται δὲ καὶ χειμῶνος, τῶν πιθακνῶν ὑπεράνω τῶν ἰπνῶν τῶν βαλανείων τιθεμένων ἢ καμίνων", paraphrasis="( (White and effective) lead white ) is also prepared in winter: ( .(In winter,) one does the same as in {phases 1 to 7 of the 1st recipe for lead white} OR as in {phases 1.1-5.1 of the 2nd recipe for lead white} ), .One places the jars (i.e., each vessel after the viscous fluid has been poured inside it) on top of the furnaces of baths OR (regular) furnaces (and lets their content dry), (. One does the same as in phases 9 to 13 of the 1st recipe for lead white} OR as in {phases 7.1 of the 2nd recipe for lead white} ) ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T205232" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα ... σκευάζεται δὲ καὶ χειμῶνος, τῶν πιθακνῶν ὑπεράνω τῶν ἰπνῶν τῶν βαλανείων τιθεμένων ἢ καμίνων", paraphrasis="( (White and effective) lead white ) is also shaped (into lozenges) in winter: ( .(In winter,) one does the same as in {phases 1 to 2 of the 1st recipe for shaping lead white (into lozenges), ) (. One puts the lead white kneaded with vinegar and made into shapes inside jars) .One places the jars on top of the furnaces of baths OR (regular) furnaces (and leaves their content to dry) ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T235335" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα ... σκευάζεται δὲ καὶ χειμῶνος, τῶν πιθακνῶν ὑπεράνω τῶν ἰπνῶν τῶν βαλανείων τιθεμένων ἢ καμίνων · ἡ γὰρ ἀναφερομένη θερμασία τὸ αὐτὸ δρᾷ τῷ ἡλίῳ", paraphrasis="( In the winter recipes for lead white and for shaping lead white (into lozenges), placing the jars on top of the furnaces of baths OR (regular) furnaces instead of under the summer sun is an equally appropriate solution ) ", manifestation="implicit", source="tlg0656_tlg001", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T000509" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="θέρους μέντοι ἐργαστέον τὰ προειρημένα ... σκευάζεται δὲ καὶ χειμῶνος, τῶν πιθακνῶν ὑπεράνω τῶν ἰπνῶν τῶν βαλανείων τιθεμένων ἢ καμίνων · ἡ γὰρ ἀναφερομένη θερμασία τὸ αὐτὸ δρᾷ τῷ ἡλίῳ", paraphrasis="The heat rising up (from the furnaces of the baths and from regular furnaces) has the same effect (over the processes for producing lead white and for shaping lead white) as the (summer) sun ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.S002022" [label="SUPP", text="ἡ γὰρ ἀναφερομένη θερμασία τὸ αὐτὸ δρᾷ τῷ ἡλίῳ", locus="5.88.4_div", speaker="Dioscorides-Pedanius", form="particular-illustration", paraphrasis="\"The heat rising up (from the furnaces of the baths and from regular furnaces) has the same effect (over the processes for producing lead white and for shaping lead white) as the (summer) sun\" EXPLAINS/justifies) \"( In the winter recipes for lead white and for shaping lead white (into lozenges), placing the jars on top of the furnaces of baths OR (regular) furnaces instead of under the summer sun is an equally appropriate solution )\" ", manifestation="explicit", color="lightgoldenrodyellow", label_color="grey", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.T155024" [label="THES", locus="5.88.4_div", speaker="Dioscorides-Pedanius", text="κάλλιστον δὲ ἡγητέον τὸ ἐν Ῥόδῳ σκευασθὲν ἢ ἐν Κορίνθῳ ἢ ἐν Λακεδαίμονι, δευτερεύει δὲ τὸ ἐκ Δικαιαρχίας", paraphrasis="Those which must be considered the best varieties (of lead white) (for its medical uses) are that prepared in Rhodes, that prepared in Corinth, or that made in Lacedaemon; that from Dicaiarchia is second to these ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0656_tlg001.T161627" [label="THES", locus="5.88.6_div", speaker="Dioscorides-Pedanius", text="δύναμιν δὲ ἔχει ψυκτικήν, ἐμπλαστικήν, μαλακτικήν, πληρωτικήν, λεπτυντικήν, ἔτι δὲ πράως κατασταλτικὴν ὑπεροχῶν καὶ κατουλωτικήν, μειγνύμενον κηρωταῖς καὶ λιπαραῖς ἐμπλάστροις καὶ τροχίσκοις", paraphrasis="(Lead white)'s property is: cooling, adhesive-malleability-inducing, softening, filling, thinning, moderately controlling of excrescences, and – when mixed with cerates, fatty plasters and lozenges – cicatrising ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"w0007112.P664643" [label="PROP", shape="doubleoctagon", style="rounded,filled", color="ghostwhite", label_color="lightslategrey", paraphrasis="Lead white is a cooling substance "];

"tlg0656_tlg001.S170340" [label="SUPP", text="δύναμιν δὲ ἔχει ψυκτικήν, ἐμπλαστικήν, μαλακτικήν, πληρωτικήν, λεπτυντικήν, ἔτι δὲ πράως κατασταλτικὴν ὑπεροχῶν καὶ κατουλωτικήν, μειγνύμενον κηρωταῖς καὶ λιπαραῖς ἐμπλάστροις καὶ τροχίσκοις · ἐστι δὲ καὶ", locus="5.88.6_div", speaker="Dioscorides-Pedanius", form="contrast", paraphrasis="\"(Lead white)'s property is: cooling, adhesive-malleability-inducing, softening, filling, thinning, moderately controlling of excrescences, and – when mixed with cerates, fatty plasters and lozenges – cicatrising\" CONTEXT) \"(Lead white) is among the destructive substances\" ", manifestation="explicit", color="wheat", label_color="rosybrown", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0656_tlg001"];

"tlg0656_tlg001.T165736" [label="THES", locus="5.88.6_div", speaker="Dioscorides-Pedanius", text="ἐστι δὲ καὶ τῶν ἀναιρετικῶν", paraphrasis="(Lead white) is among the destructive substances ", manifestation="explicit", source="tlg0656_tlg001", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"w0007112.P664642" [label="PROP", shape="doubleoctagon", style="rounded,filled", color="ghostwhite", label_color="lightslategrey", paraphrasis="Lead white is a harmful substance "];

"tlg0007_tlg112.S202335" [label="SUPP", text="πρῶτον οὐ οὖν οὐ? δοκεῖ σοι περιψύχεσθαι R: προψύχεσθαι μὲν ὑπὸ τοῦ ἀέρος τὸ ὕδωρ ἔξωθεν ἐμπίπτοντος Anonymus: ἐκπίπτοντος, ὁ δʼ ἀὴρ μᾶλλον ἰσχύειν ib. W: ἰσχύει πρὸς τοὺς λίθους καὶ τοὺς ἄκμονας τοὺς ἄκμονας] τὰς μολιβδίδας Psellus. τὰς ἀκόνας S ἀπερειδόμενος; οὐ γὰρ ἐῶσιν αὐτόν, ὥσπερ τὰ χαλκᾶ *: ... διʼ ὅλου καὶ καὶ] prius om. Psellus ἰσχυρὰν γίγνεσθαι γίνεσθαι idem: γενέσθαι τὴν περίψυξιν. διὸ καὶ χειμῶνος οἱ ποταμοὶ ψυχρότεροι γίγνονται τῆς θαλάττης - ἰσχύει γὰρ ἐν αὐτοῖς ὁ ψυχρὸς ἀὴρ ἀνακλώμενος Doehnerus ex Psello: ἀναλώμενος, ἐν δὲ τῇ θαλάττῃ διὰ βάθος ἐκλύεται πρὸς μηδὲν ἀντερείδων. κατʼ ἄλλον δὲ τρόπον", locus="690f", speaker="Plutarchus", form="contrast", paraphrasis="[omitted] CONTEXT) \"{It is likely that} thinner waters are cooled more (intensely) by the surrounding cold\" ", manifestation="explicit", color="wheat", label_color="rosybrown", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.S202335_to_omitted_ELEMENTS_unspecified" [label="ELEM", gephi_omitted="true", gephi_unspecified="true", fontsize="11", color="whitesmoke", label_color="darkgrey", style="dotted,filled,rounded", shape="box", source="tlg0007_tlg112"];

"tlg0007_tlg112.T150609" [label="THES", locus="691a", speaker="Plutarchus", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων περιψύχεσθαι μᾶλλον ... ὑπὸ τοῦ ψυχροῦ", paraphrasis="{It is likely that} thinner waters are cooled more (intensely) by the surrounding cold ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T151258" [label="THES", locus="691a", speaker="Plutarchus", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων ... ὑπὸ τοῦ ψυχροῦ - κρατεῖται γὰρ διʼ ἀσθένειαν", paraphrasis="{It is likely that} thinner waters are dominated (by the cold) because of their weakness ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T181906" [label="THES", locus="691a", speaker="Plutarchus", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων ... ὑπὸ τοῦ ψυχροῦ - κρατεῖται γὰρ διʼ ἀσθένειαν", paraphrasis="( {It is likely that} thinner waters have more weakness ) ", manifestation="implicit", source="tlg0007_tlg112", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S152106" [label="SUPP", text="κρατεῖται γὰρ διʼ ἀσθένειαν", locus="691b", speaker="Plutarchus", form="from-cause-to-effect", paraphrasis="\"{It is likely that} thinner waters are dominated (by the cold) because of their weakness\" JUSTIFIES) \"{It is likely that} thinner waters are cooled more (intensely) by the surrounding cold\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T174946" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ", paraphrasis="(Leaden) 'whetstones' and pebbles thin the water (contained in the vessels in which they are plunged) ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T152959" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ", paraphrasis="(Leaden) 'whetstones' and pebbles thin the water (contained in the vessels in which they are plunged) by gathering and drawing down from it the turbid and earthy parts that have become mixed with it ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T184712" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ", paraphrasis="(Leaden) 'whetstones' and pebbles gather and draw down from the water (contained in the vessels in which they are plunged) the turbid and earthy parts that have become mixed with it ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S184328" [label="SUPP", text="ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ", locus="691b", speaker="Plutarchus", form="from-cause-to-effect", paraphrasis="( \"(Leaden) 'whetstones' and pebbles gather and draw down from the water (contained in the vessels in which they are plunged) the turbid and earthy parts that have become mixed with it\" + \"(Leaden) 'whetstones' and pebbles thin the water (contained in the vessels in which they are plunged) by gathering and drawing down from it the turbid and earthy parts that have become mixed with it\" JUSTIFIES) \"(Leaden) 'whetstones' and pebbles thin the water (contained in the vessels in which they are plunged)\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T174153" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον ... τὸ ὕδωρ γενόμενον", paraphrasis="As a result of (leaden) 'whetstones' and pebbles thinning the water (contained in the vessels in which they are plunged), the water becomes thinner ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S181621" [label="SUPP", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων ... ὑπὸ τοῦ ψυχροῦ - κρατεῖται γὰρ διʼ ἀσθένειαν", locus="691a", speaker="Plutarchus", form="general-to-particular", paraphrasis="( \"( {It is likely that} thinner waters have more weakness )\" JUSTIFIES) \"( As a result of the water (contained in vessels) becoming thinner as caused by (leaden) 'whetstones' and pebbles thinning it, the water becomes weaker )\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T175820" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον", paraphrasis="( As a result of the water (contained in vessels) becoming thinner as caused by (leaden) 'whetstones' and pebbles thinning it, the water becomes weaker ) ", manifestation="implicit", source="tlg0007_tlg112", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S182325" [label="SUPP", text="εἰκός ἐστι τὰ λεπτότερα τῶν ὑδάτων περιψύχεσθαι μᾶλλον ... ὑπὸ τοῦ ψυχροῦ - κρατεῖται γὰρ διʼ ἀσθένειαν ... αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον", locus="691a", speaker="Plutarchus", form="general-to-particular", paraphrasis="( \"{It is likely that} thinner waters are cooled more (intensely) by the surrounding cold\" JUSTIFIES) \"As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T181116" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ ... ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον μᾶλλον ὑπὸ περιψύξεως κρατεῖσθαι", paraphrasis="As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S144521" [label="SUPP", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες λεπτύνουσι τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ, ὥστε λεπτότερον καὶ ἀσθενέστερον τὸ ὕδωρ γενόμενον μᾶλλον ὑπὸ περιψύξεως κρατεῖσθαι", locus="691b", speaker="Plutarchus", form="particular-illustration", paraphrasis="( \"As a result of the water (contained in vessels) becoming thinner and weaker as caused by (leaden) 'whetstones' and pebbles thinning it, the water is more effectively dominated by environmental cooling\" JUSTIFIES) \"{It is not strange if} both stone and lead, 'exerting counter-pressure against' {= supporting} the coldness (of the water contained in vessels in which they are plunged), 'tighten' {= intensify} it\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T185715" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ ... καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες", paraphrasis="( Leaden 'whetstones' and pebbles gather and draw down from the water contained in the vessels in which they are plunged the turbid and earthy parts that have become mixed with it because they are cold or produce cold ) ", manifestation="implicit", source="tlg0007_tlg112", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T190127" [label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ ... καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες", paraphrasis="( Leaden 'whetstones' and pebbles are cold or produce cold ) ", manifestation="implicit", source="tlg0007_tlg112", color="white", label_color="dimgrey", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S190452" [label="SUPP", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ ... καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες", locus="691b", speaker="Plutarchus", form="from-cause-to-effect", paraphrasis="( \"( Leaden 'whetstones' and pebbles gather and draw down from the water contained in the vessels in which they are plunged the turbid and earthy parts that have become mixed with it because they have a cooling effect )\" + \"( Leaden 'whetstones' and pebbles are cold or produce cold )\" JUSTIFIES) \"(Leaden) 'whetstones' and pebbles gather and draw down from the water (contained in the vessels in which they are plunged) the turbid and earthy parts that have become mixed with it\" ) ", manifestation="implicit", color="ghostwhite", label_color="darkgrey", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

"tlg0007_tlg112.T133442" [label="THES", locus="691b", speaker="Plutarchus", text="ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν", paraphrasis="Lead is among the naturally cold (substances) ", manifestation="explicit", source="tlg0007_tlg112", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.S191342" [label="SUPP", text="καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες τῆ ... πυκνότητι τὸ ψυχρὸν διὰ βάθους ποιοῦσι", locus="691b", speaker="Plutarchus", form="general-to-particular", paraphrasis="\"Lead is among the naturally cold (substances)\" + [omitted] JUSTIFIES) \"( Leaden 'whetstones' and pebbles are cold or produce cold )\" ", manifestation="explicit", color="lightsteelblue", label_color="steelblue", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0007_tlg112"];

