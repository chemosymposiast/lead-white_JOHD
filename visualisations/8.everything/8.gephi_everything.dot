"caley_richards_1956.T211944" [label="THES", locus="p. 188", speaker="Caley-Earle-R., Richards-John-F.", text="What has been ---- ------ ---------- -- ---- the air itself --- --- ----- ---- -- --- ------- ---------- -------- ------ ------ ------- -- ------- ----- ---- --------- -- --- ------ ----- --------- ---- -- --- an- cients", paraphrasis="It has generally been overlooked in scholarly literature about basic lead carbonate production methods in antiquity that \"In the small-scale processes used by the ancients to produce basic lead carbonate, air and the water used in the washing operations provided enough carbon dioxide to obtain this product\" ", manifestation="explicit", source="caley_richards_1956", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

