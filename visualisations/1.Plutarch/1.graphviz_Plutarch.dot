"tlg0007_tlg112.T185715" [label=<<b>impl. THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>( Leaden 'whetstones' and pebbles gather and draw<br/>down from the water contained in the vessels in<br/>which they are plunged the turbid and earthy parts<br/>that have become mixed with it because they are<br/>cold or produce cold )<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... τε χάλικες"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ ... καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες", paraphrasis="( Leaden 'whetstones' and pebbles gather and draw down from the water contained in the vessels in which they are plunged the turbid and earthy parts that have become mixed with it because they are cold or produce cold ) ", manifestation="implicit", source="tlg0007_tlg112", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

"tlg0007_tlg112.T190127" [label=<<b>impl. THESIS</b><br/>          Plutarchus          <br/>691b<br/><i>( Leaden 'whetstones' and pebbles are cold or<br/>produce cold )<br/></i><font point-size="12">"αἱ δʼ ἀκόναι ... τε χάλικες"</font>>, gephi_label="THES", locus="691b", speaker="Plutarchus", text="αἱ δʼ ἀκόναι καὶ οἱ χάλικες ... τὸ ὕδωρ, ὅ τι θολερὸν καὶ γεῶδες ἀναμέμικται, τοῦτο συνάγοντες καὶ κατασπῶντες ἀπʼ αὐτοῦ ... καὶ μὴν ὅ τε μόλιβδος τῶν φύσει ψυχρῶν ἐστιν ... οἵ τε χάλικες", paraphrasis="( Leaden 'whetstones' and pebbles are cold or produce cold ) ", manifestation="implicit", source="tlg0007_tlg112", fillcolor="#fcfffd", color="#666666", style="rounded,filled,dashed", shape="box", margin="0.30,0.1"];

