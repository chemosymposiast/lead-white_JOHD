"tlg0093_tlg004.T183406" [label=<<b>THESIS</b><br/>       pigment-grinders       <br/>55<br/><i>The four colours made by kyanos from itself come<br/>about by technical means<br/></i><font point-size="12">"τὸν μὲν κύανον ... τέχνῃ γίνεται"</font>>, gephi_label="THES", locus="55", speaker="pigment-grinders", text="τὸν μὲν κύανον ἐξ ἑαυτοῦ ποιεῖν χρώματα τέτταρα ... ταῦτά τε δὴ τέχνῃ γίνεται", paraphrasis="The four colours made by kyanos from itself come about by technical means ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S183406" [label=<<b>SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: analogy</i><br/><font point-size="12">"τὸν μὲν κύανον ... καὶ ἔτι"</font>>, gephi_label="SUPP", text="τὸν μὲν κύανον ἐξ ἑαυτοῦ ποιεῖν χρώματα τέτταρα ... ταῦτά τε δὴ τέχνῃ γίνεται καὶ ἔτι", locus="55", speaker="Theophrastus", form="analogy", paraphrasis="\"The four colours made by kyanos from itself come about by technical means\" CONTEXT) \"Lead white comes about by technical means\" ", manifestation="explicit", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S183406_func" [label="CONTEXTUALIZES", gephi_label="con", gephi_omitted="false", fontsize="11", fillcolor="#ecd4bb", color="#b39c84", style="filled", shape="ellipse"];

