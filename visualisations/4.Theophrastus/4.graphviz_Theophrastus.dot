"tlg0093_tlg004.T183406" -> "tlg0093_tlg004.S183406_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0093_tlg004.T170246" [label=<<b>THESIS</b><br/>         Theophrastus         <br/>55<br/><i>Lead white comes about by technical means<br/></i><font point-size="12">"τέχνῃ γίνεται ... τὸ ψιμύθιον"</font>>, gephi_label="THES", locus="55", speaker="Theophrastus", text="τέχνῃ γίνεται ... τὸ ψιμύθιον", paraphrasis="Lead white comes about by technical means ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.S150529" [label=<<b>impl. SUPPORT</b><br/>         Theophrastus         <br/>55<br/><i>form: generalization</i><br/><font point-size="12">"τέχνῃ γίνεται ... τὸ ψιμύθιον. ... γὰρ"</font>>, gephi_label="SUPP", text="τέχνῃ γίνεται ... τὸ ψιμύθιον. ... γὰρ", locus="55", speaker="Theophrastus", form="generalization", paraphrasis="( \"Lead white comes about by technical means\" CONTEXT) \".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white\" ) ", manifestation="implicit", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse", margin="0.05,0.02", source="tlg0093_tlg004"];

"tlg0093_tlg004.S150529_func" [label="CONTEXTUALIZES", gephi_label="(con)", gephi_omitted="false", fontsize="11", fillcolor="#f6ede6", color="#b3a89a", style="dashed,filled", shape="ellipse"];

"tlg0093_tlg004.S150529_func" -> "tlg0093_tlg004.T151115" [color="#b3a89a", style="dashed,filled"];

"tlg0093_tlg004.S150529_employed" [label="EMPLOYED IN", gephi_label="in", fontsize="11", fillcolor="#ffe6cc", color="#d79c02", gephi_omitted="false", shape="ellipse", style="filled"];

"tlg0093_tlg004.T170246" -> "tlg0093_tlg004.S150529_employed" [dir=none, color="#d79c02", style="solid"];

"tlg0093_tlg004.T151115" [label=<<b>THESIS</b><br/>         Theophrastus         <br/>55<br/><i>.Lead the size of a brick is placed over vinegar<br/>in (closed) jars, .They wait for lead to acquire<br/>thickness{, which happens in a maximum of 10<br/>days}, .They open the jars, .They scrape away from<br/>the lead something {resembling a mold}, repeating<br/>this until they have consumed it completely, .They<br/>rub what has been scraped away in a grinding-bowl,<br/>.They always filter off what is being rubbed, .The<br/>final precipitate is lead white<br/></i><font point-size="12">"τίθεται γὰρ μόλυβδος ... τὸ ψιμύθιον"</font>>, gephi_label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον", paraphrasis=".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white ", manifestation="explicit", source="tlg0093_tlg004", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.T151115_to_tlg0093_tlg004.T180430_1" [label=<by inclusion,<br/>ENTAILS>, fontsize="11", style="rounded,filled", fillcolor="#f0faf0", color="#82b366", shape="house"];

