"tlg0093_tlg004.q151115002" [label=<<b>2</b><br/><i>They wait for lead to acquire<br/>thickness {, which happens in<br/>a maximum of 10 days}<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="They wait for lead to acquire thickness {, which happens in a maximum of 10 days} ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0093_tlg004.q151115003" [label=<<b>3</b><br/><i>They open the jars<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="They open the jars ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0093_tlg004.q151115004" [label=<<b>4</b><br/><i>They scrape away from the lead<br/>something {resembling a mold},<br/>repeating this until they have<br/>consumed it completely<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0093_tlg004.q151115005" [label=<<b>5</b><br/><i>They rub what has been scraped<br/>away in a grinding-bowl<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="They rub what has been scraped away in a grinding-bowl ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0093_tlg004.q151115006" [label=<<b>6</b><br/><i>They always filter off what is<br/>being rubbed<br/></i>>, gephi_label="ph.", phase_number="6", paraphrasis="They always filter off what is being rubbed ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0093_tlg004.q151115007" [label=<<b>7</b><br/><i>The final precipitate is lead<br/>white<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="The final precipitate is lead white ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

