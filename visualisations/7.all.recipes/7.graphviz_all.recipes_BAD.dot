subgraph source_caley_richards_1956 {
label="caley_richards_1956";

"caley_richards_1956.T212135" [label=<<b>THESIS</b><br/>Caley-Earle-R., Richards-John-F.<br/>p. 188<br/><i>We performed in miniature the process described by<br/>Theophrastus to produce lead white: .We supported<br/>blocks of lead just above a 5% acetic acid<br/>solution in an open vessel, .White crusts formed<br/>on the blocks {due to corrosion}, .{Repeatedly},<br/>{at intervals of about 10 days}, we scraped off<br/>these crusts, .We identified the obtained product<br/>as a lead acetate containing only a small<br/>proportion of lead carbonate, .We dissolved this<br/>in tap water, .{Almost immediately} we observed a<br/>turbidity {due to the formation of basic lead<br/>carbonate}, .We let the solution stand for a few<br/>hours, .A considerable amount of lead carbonate<br/>precipitated {due to the solution having absorbed<br/>enough carbon dioxide from the air}, ( .We<br/>obtained lead white in the same way as in<br/>Theophrastus's process )<br/></i><font point-size="12">"performing in miniature ... this way"</font>>, gephi_label="THES", locus="p. 188", speaker="Caley-Earle-R., Richards-John-F.", text="performing in miniature ··· ······· ···· ········· by Theophrastus. Lead blocks were ········· ···· ····· · five per cent ······ acid solution ·· ·· open vessel, ··· the white crusts that ···· ······ ·· the blocks by corrosion ···· ······· ··· ·· ········· ·· ····· ten days. The product was ... ········ almost immediately, ··· ····· the solution had ····· ··· · few hours it absorbed enough carbon dioxide from the air ·· ····· ··· ···- ·········· ·· · ············ ······ of carbonate. The statements of Theophrastus suggest that, in the process ·· ·········, white lead formed in just this way", paraphrasis="We performed in miniature the process described by Theophrastus to produce lead white: .We supported blocks of lead just above a 5% acetic acid solution in an open vessel, .White crusts formed on the blocks {due to corrosion}, .{Repeatedly}, {at intervals of about 10 days}, we scraped off these crusts, .We identified the obtained product as a lead acetate containing only a small proportion of lead carbonate, .We dissolved this in tap water, .{Almost immediately} we observed a turbidity {due to the formation of basic lead carbonate}, .We let the solution stand for a few hours, .A considerable amount of lead carbonate precipitated {due to the solution having absorbed enough carbon dioxide from the air}, ( .We obtained lead white in the same way as in Theophrastus's process ) ", manifestation="explicit", source="caley_richards_1956", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

subgraph cluster_caley_richards_1956_T212135_caley_richards_1956_Q163717 {
label=<<font color='#82b366'>Sequence</font>>;

peripheries=1;

"caley_richards_1956.q163717001" [label=<<b>1</b><br/><i>We supported blocks of lead<br/>just above a 5% acetic acid<br/>solution in an open vessel<br/></i>>, gephi_label="ph.", phase_number="1", paraphrasis="We supported blocks of lead just above a 5% acetic acid solution in an open vessel ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"caley_richards_1956.q163717002" [label=<<b>2</b><br/><i>White crusts formed on the<br/>blocks {due to corrosion}<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="White crusts formed on the blocks {due to corrosion} ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"caley_richards_1956.q163717003" [label=<<b>3</b><br/><i>{Repeatedly}, {at intervals of<br/>about 10 days}, we scraped off<br/>these crusts<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="{Repeatedly}, {at intervals of about 10 days}, we scraped off these crusts ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"caley_richards_1956.q163717004" [label=<<b>4</b><br/><i>We identified the obtained<br/>product as a lead acetate<br/>containing only a small<br/>proportion of lead carbonate<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="We identified the obtained product as a lead acetate containing only a small proportion of lead carbonate ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"caley_richards_1956.q163717005" [label=<<b>5</b><br/><i>We dissolved this in tap water<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="We dissolved this in tap water ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"caley_richards_1956.q163717006" [label=<<b>6</b><br/><i>{Almost immediately} we<br/>observed a turbidity {due to<br/>the formation of basic lead<br/>carbonate}<br/></i>>, gephi_label="ph.", phase_number="6", paraphrasis="{Almost immediately} we observed a turbidity {due to the formation of basic lead carbonate} ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"caley_richards_1956.q163717007" [label=<<b>7</b><br/><i>We let the solution stand for<br/>a few hours<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="We let the solution stand for a few hours ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"caley_richards_1956.q163717008" [label=<<b>8</b><br/><i>A considerable amount of lead<br/>carbonate precipitated {due to<br/>the solution having absorbed<br/>enough carbon dioxide from the<br/>air}<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="A considerable amount of lead carbonate precipitated {due to the solution having absorbed enough carbon dioxide from the air} ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"caley_richards_1956.q163717009" [label=<<b>9</b><br/><i>( We obtained lead white in<br/>the same way as in<br/>Theophrastus's process )<br/></i>>, gephi_label="ph.", phase_number="9", paraphrasis="( We obtained lead white in the same way as in Theophrastus's process ) ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

