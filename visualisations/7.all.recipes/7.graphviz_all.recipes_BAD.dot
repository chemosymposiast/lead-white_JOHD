"tlg0656_tlg001.q213928002" [label=<<b>2</b><br/><i>Place a piece of lead on a<br/>lattice<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="Place a piece of lead on a lattice ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928003" [label=<<b>3</b><br/><i>Lay the lattice with the lead<br/>onto the mouth of the jar<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="Lay the lattice with the lead onto the mouth of the jar ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928004" [label=<<b>4</b><br/><i>Above, throw over covers<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="Above, throw over covers ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928005" [label=<<b>5</b><br/><i>Wait until the lead, crumbling<br/>down, has strained through the<br/>lattice<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="Wait until the lead, crumbling down, has strained through the lattice ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928006" [label=<<b>6</b><br/><i>Decant away the clean fluid<br/>that floats on top of the<br/>vinegar<br/></i>>, gephi_label="ph.", phase_number="6", paraphrasis="Decant away the clean fluid that floats on top of the vinegar ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928007" [label=<<b>7</b><br/><i>Pour the remaining viscous<br/>fluid into a vessel<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="Pour the remaining viscous fluid into a vessel ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928008" [label=<<b>8</b><br/><i>Let the viscous fluid dry<br/>under the sun<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="Let the viscous fluid dry under the sun ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928009" [label=<<b>9</b><br/><i>Grind the dried substance<br/></i>>, gephi_label="ph.", phase_number="9", paraphrasis="Grind the dried substance ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928010" [label=<<b>10</b><br/><i>Sift the ground substance<br/></i>>, gephi_label="ph.", phase_number="10", paraphrasis="Sift the ground substance ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928011" [label=<<b>11</b><br/><i>The substance that is sifted<br/>away is the better variety of<br/>white and effective lead white<br/></i>>, gephi_label="ph.", phase_number="11", paraphrasis="The substance that is sifted away is the better variety of white and effective lead white ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928012" [label=<<b>12</b><br/><i>Grind and sift what remains<br/>above the sieve of the solid<br/>substance {, repeat, and do it<br/>again a third and fourth time}<br/></i>>, gephi_label="ph.", phase_number="12", paraphrasis="Grind and sift what remains above the sieve of the solid substance {, repeat, and do it again a third and fourth time} ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

"tlg0656_tlg001.q213928013" [label=<<b>13</b><br/><i>The substances that are sifted<br/>away at each repeated grinding<br/>and sifting are progressively<br/>worse varieties of white and<br/>effective lead white<br/></i>>, gephi_label="ph.", phase_number="13", paraphrasis="The substances that are sifted away at each repeated grinding and sifting are progressively worse varieties of white and effective lead white ", shape="box", style="rounded,filled", color="#9673a6", fillcolor="#f9edff"];

