subgraph source_tlg0656_tlg001 {
label="tlg0656_tlg001";

"tlg0656_tlg001.T213927" [label=<<b>THESIS</b><br/>     Dioscorides-Pedanius     <br/>5.88.1 (of <i>div</i>)<br/><i>In order for (white and effective) lead white to<br/>come about in the best variety - to be used for<br/>ophthalmological properties - as well as in worse<br/>varieties, .(In summer, ) pour most pungent<br/>vinegar into a broad-mouthed jar OR pot-bellied<br/>clay jar, .Place a leaden brick on a lattice of<br/>reeds, .Lay the lattice of reeds with the leaden<br/>brick onto the mouth of the pot, .Above, throw<br/>over covers to prevent vinegar from evaporating,<br/>.Wait until (the leaden brick), crumbling down,<br/>has strained through (the lattice), .Decant away<br/>the clean fluid that floats on top (of the vinegar<br/>after the leaden brick has crumbled down in it),<br/>.Pour the (remaining) viscous fluid into a vessel,<br/>.Let the viscous fluid dry under the sun, .Smooth<br/>the dried substance with a hand-mill OR in any<br/>way, .Sift the ground substance, .The substance<br/>that is sifted away is the better variety of<br/>(white and effective) lead white, that should be<br/>picked also for ophthalmological properties, .Thin<br/>(with a hand-mill OR in any way) and sift what<br/>remains (above the sieve) of the solid substance<br/>{, repeat, and do it again a third and fourth<br/>time}, .The substances that are sifted away at<br/>each repeated thinning and sifting are<br/>progressively worse varieties of (white and<br/>effective) lead white<br/></i><font point-size="12">"ψιμύθιον δὲ γίνεται ... τέταρτον ποιητέον"</font>>, gephi_label="THES", locus="5.88.1_div", speaker="Dioscorides-Pedanius", text="ψιμύθιον δὲ γίνεται οὕτως · εἰς πιθάκνην πλατύστομον ἢ κεραμεᾶν γάστραν ἐγχέας δριμύτατον ὄξος ἀπέρεισαι μολυβδίνην πλίνθον ἐπὶ τὸ στόμα τοῦ κεραμίου, προυποκειμένου καλαμίνου ῥίπου, ἄνωθέν τε αὐτῆς ἐπίρριψον σκεπάσματα πρὸς τὸ μὴ διαπνεῖσθαι τὸ ὀξος · ὡς δʼ ἂν καταρρυεῖσα διαπέσῃ, τὸ μὲν ἐπαιωρούμενον καὶ καθαρὸν ὑγρὸν ἀπηθητέον, τὸ δὲ γλοιῶδες εἰς ἀγγεῖον ἐγχυτέον καὶ ξηραντέον ἐν ἡλίῳ. εἶτα ἀλεστέον ἐν χειρομυλίῳ ἢ λεαντέον ἄλλως καὶ σηστέον, 2 καὶ μετὰ ταῦτα τὸ λοιπὸν τοῦ στερεμνίου λεπτοποιητέον καὶ σηστέον, ἐναλλάξ τε τὰ αὐτὰ καὶ τρίτον καὶ τέταρτον ποιητέον", paraphrasis="In order for (white and effective) lead white to come about in the best variety - to be used for ophthalmological properties - as well as in worse varieties, .(In summer, ) pour most pungent vinegar into a broad-mouthed jar OR pot-bellied clay jar, .Place a leaden brick on a lattice of reeds, .Lay the lattice of reeds with the leaden brick onto the mouth of the pot, .Above, throw over covers to prevent vinegar from evaporating, .Wait until (the leaden brick), crumbling down, has strained through (the lattice), .Decant away the clean fluid that floats on top (of the vinegar after the leaden brick has crumbled down in it), .Pour the (remaining) viscous fluid into a vessel, .Let the viscous fluid dry under the sun, .Smooth the dried substance with a hand-mill OR in any way, .Sift the ground substance, .The substance that is sifted away is the better variety of (white and effective) lead white, that should be picked also for ophthalmological properties, .Thin (with a hand-mill OR in any way) and sift what remains (above the sieve) of the solid substance {, repeat, and do it again a third and fourth time}, .The substances that are sifted away at each repeated thinning and sifting are progressively worse varieties of (white and effective) lead white ", manifestation="explicit", source="tlg0656_tlg001", fillcolor="#f0faf0", color="#82b366", style="rounded,filled", shape="box", margin="0.30,0.1"];

subgraph cluster_tlg0656_tlg001_T213927_tlg0656_tlg001_Q213927 {
label=<<font color='#82b366'>Sequence</font>>;

peripheries=1;

"tlg0656_tlg001.q213927001" [label=<<b>1</b><br/><i>(In summer, ) pour most<br/>pungent vinegar into a<br/>broad-mouthed jar<br/></i>>, gephi_label="ph.", phase_number="1", paraphrasis="(In summer, ) pour most pungent vinegar into a broad-mouthed jar ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927002" [label=<<b>2</b><br/><i>Place a leaden brick on a<br/>lattice of reeds<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="Place a leaden brick on a lattice of reeds ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0656_tlg001.q213927003" [label=<<b>3</b><br/><i>Lay the lattice of reeds with<br/>the leaden brick onto the<br/>mouth of the pot (i.e., of the<br/>broad-mouthed jar)<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="Lay the lattice of reeds with the leaden brick onto the mouth of the pot (i.e., of the broad-mouthed jar) ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927004" [label=<<b>4</b><br/><i>Above, throw over covers (to<br/>prevent vinegar from<br/>evaporating)<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="Above, throw over covers (to prevent vinegar from evaporating) ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927005" [label=<<b>5</b><br/><i>Wait until (the leaden brick),<br/>crumbling down, has strained<br/>through (the lattice)<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="Wait until (the leaden brick), crumbling down, has strained through (the lattice) ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927006" [label=<<b>6</b><br/><i>Decant away the clean fluid<br/>that floats on top (of the<br/>vinegar after the leaden brick<br/>has crumbled down in it)<br/></i>>, gephi_label="ph.", phase_number="6", paraphrasis="Decant away the clean fluid that floats on top (of the vinegar after the leaden brick has crumbled down in it) ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0656_tlg001.q213927007" [label=<<b>7</b><br/><i>Pour the (remaining) viscous<br/>fluid into a vessel<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="Pour the (remaining) viscous fluid into a vessel ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0656_tlg001.q213927008" [label=<<b>8</b><br/><i>Let the viscous fluid dry<br/>under the sun<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="Let the viscous fluid dry under the sun ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0656_tlg001.q213927009" [label=<<b>9</b><br/><i>Grind the dried substance with<br/>a hand-mill<br/></i>>, gephi_label="ph.", phase_number="9", paraphrasis="Grind the dried substance with a hand-mill ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927010" [label=<<b>10</b><br/><i>Sift the ground substance<br/></i>>, gephi_label="ph.", phase_number="10", paraphrasis="Sift the ground substance ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927011" [label=<<b>11</b><br/><i>The substance that is sifted<br/>away is the better variety of<br/>(white and effective) lead<br/>white, that should be picked<br/>also for ophthalmological<br/>properties<br/></i>>, gephi_label="ph.", phase_number="11", paraphrasis="The substance that is sifted away is the better variety of (white and effective) lead white, that should be picked also for ophthalmological properties ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"tlg0656_tlg001.q213927012" [label=<<b>12</b><br/><i>Thin (with a hand-mill) and<br/>sift what remains (above the<br/>sieve) of the solid substance<br/>{, repeat, and do it again a<br/>third and fourth time}<br/></i>>, gephi_label="ph.", phase_number="12", paraphrasis="Thin (with a hand-mill) and sift what remains (above the sieve) of the solid substance {, repeat, and do it again a third and fourth time} ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"tlg0656_tlg001.q213927013" [label=<<b>13</b><br/><i>The substances that are sifted<br/>away at each repeated thinning<br/>and sifting are progressively<br/>worse varieties of (white and<br/>effective) lead white<br/></i>>, gephi_label="ph.", phase_number="13", paraphrasis="The substances that are sifted away at each repeated thinning and sifting are progressively worse varieties of (white and effective) lead white ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

