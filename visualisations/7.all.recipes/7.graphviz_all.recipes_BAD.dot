"katsaros_liritzis_laskaris_2010.q131226002" [label=<<b>2</b><br/><i>We placed vinegar on the<br/>bottom of a ceramic vessel<br/></i>>, gephi_label="ph.", phase_number="2", paraphrasis="We placed vinegar on the bottom of a ceramic vessel ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226003" [label=<<b>3</b><br/><i>We hung the brick-shaped piece<br/>of lead over the vinegar<br/>within the ceramic vessel<br/></i>>, gephi_label="ph.", phase_number="3", paraphrasis="We hung the brick-shaped piece of lead over the vinegar within the ceramic vessel ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226004" [label=<<b>4</b><br/><i>We covered the vessel with a<br/>skin {approx. 1 mm (in<br/>thickness)} quasi-transparent<br/>to air (i.e., such that it<br/>breathes)<br/></i>>, gephi_label="ph.", phase_number="4", paraphrasis="We covered the vessel with a skin {approx. 1 mm (in thickness)} quasi-transparent to air (i.e., such that it breathes) ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226005" [label=<<b>5</b><br/><i>We placed the vessel under the<br/>sun<br/></i>>, gephi_label="ph.", phase_number="5", paraphrasis="We placed the vessel under the sun ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226006" [label=<<b>6</b><br/><i>We waited {for 10 days}, {at<br/>temperatures of average 30 °C<br/>and a range of 27-55 degrees}<br/></i>>, gephi_label="ph.", phase_number="6", paraphrasis="We waited {for 10 days}, {at temperatures of average 30 °C and a range of 27-55 degrees} ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226007" [label=<<b>7</b><br/><i>We removed the skin cover<br/></i>>, gephi_label="ph.", phase_number="7", paraphrasis="We removed the skin cover ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226008" [label=<<b>8</b><br/><i>We took the brick-shaped lead<br/>out<br/></i>>, gephi_label="ph.", phase_number="8", paraphrasis="We took the brick-shaped lead out ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226009" [label=<<b>9</b><br/><i>We removed the white powdered<br/>layer (thus formed) on the<br/>surface of the lead by<br/>scratching<br/></i>>, gephi_label="ph.", phase_number="9", paraphrasis="We removed the white powdered layer (thus formed) on the surface of the lead by scratching ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226010" [label=<<b>10</b><br/><i>In a marble mortar, we washed<br/>and ground down to a fine<br/>powder the white powdered<br/>layer using a marble pestle<br/></i>>, gephi_label="ph.", phase_number="10", paraphrasis="In a marble mortar, we washed and ground down to a fine powder the white powdered layer using a marble pestle ", shape="box", fillcolor="#f0faf0", color="#82b366", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226011" [label=<<b>11</b><br/><i>We waited for it to dry out<br/>under the sun<br/></i>>, gephi_label="ph.", phase_number="11", paraphrasis="We waited for it to dry out under the sun ", shape="box", fillcolor="#e2efe2", color="#8bb477", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226012" [label=<<b>12</b><br/><i>( We obtained the white powder<br/>sample PSI-1 (which is<br/>composed of cerussite and<br/>hydrocerussite, and is<br/>therefore lead white)<br/>following Theophrastus's<br/>recipe (on the preparation of<br/>lead white) )<br/></i>>, gephi_label="ph.", phase_number="12", paraphrasis="( We obtained the white powder sample PSI-1 (which is composed of cerussite and hydrocerussite, and is therefore lead white) following Theophrastus's recipe (on the preparation of lead white) ) ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

"katsaros_liritzis_laskaris_2010.q131226013" [label=<<b>13</b><br/><i>We applied it on a prepared<br/>wooden surface with a gypsum<br/>support<br/></i>>, gephi_label="ph.", phase_number="13", paraphrasis="We applied it on a prepared wooden surface with a gypsum support ", shape="box", fillcolor="#c1d5c2", color="#a2b9a3", style="rounded,filled"];

