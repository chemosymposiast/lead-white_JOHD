"tlg0093_tlg004.T151115" [label="THES", locus="55", speaker="Theophrastus", text="τίθεται γὰρ μόλυβδος ὑπὲρ ὄξους ἐν πίθοις ἡλίκον πλίνθος. ὅταν δὲ λάβῃ πάχος, λαμβάνει δὲ μάλιστα ἐν ἡμέραις δέκα, τότʼ ἀνοίγουσιν, εἶτʼ ἀποξύουσιν ὥσπερ εὐρῶτά τινα ἀπʼ αὐτοῦ, καὶ πάλιν, ἕως ἄν καταναλώσωσι. τὸ δʼ ἀποξυόμενον ἐν τριπτῆρι τρίβουσι καὶ ἀφηθοῦσιν ἀεὶ, τὸ δʼ ἔσχατον ὑφιστάμενόν ἐστι τὸ ψιμύθιον", paraphrasis=".Lead the size of a brick is placed over vinegar in (closed) jars, .They wait for lead to acquire thickness{, which happens in a maximum of 10 days}, .They open the jars, .They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely, .They rub what has been scraped away in a grinding-bowl, .They always filter off what is being rubbed, .The final precipitate is lead white ", manifestation="explicit", source="tlg0093_tlg004", color="palegreen", label_color="darkseagreen", style="rounded,filled", shape="box", margin="0.30,0.1"];

"tlg0093_tlg004.q151115001" [label="ph.", phase_number="1", paraphrasis="Lead the size of a brick is placed over vinegar in (closed) jars ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115002" [label="ph.", phase_number="2", paraphrasis="They wait for lead to acquire thickness {, which happens in a maximum of 10 days} ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115003" [label="ph.", phase_number="3", paraphrasis="They open the jars ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115004" [label="ph.", phase_number="4", paraphrasis="They scrape away from the lead something {resembling a mold}, repeating this until they have consumed it completely ", shape="box", color="mediumaquamarine", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115005" [label="ph.", phase_number="5", paraphrasis="They rub what has been scraped away in a grinding-bowl ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115006" [label="ph.", phase_number="6", paraphrasis="They always filter off what is being rubbed ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.q151115007" [label="ph.", phase_number="7", paraphrasis="The final precipitate is lead white ", shape="box", color="palegreen", label_color="darkseagreen", style="rounded,filled"];

"tlg0093_tlg004.P151115" [label="PROP", shape="doubleoctagon", style="rounded,filled", color="ghostwhite", label_color="lightslategrey", paraphrasis="{Theophrastus recipe} To produce lead white: . Place a piece of lead over vinegar in closed jars, .Wait for lead to acquire thickness .Open the jars, .Scrape away from the lead the substance that has formed on its surface, repeating this until you have consumed it completely, .Grind what you have scraped away, .Filter off what you are grinding, .The final precipitate is lead white "];

"tlg0093_tlg004.q151116001" [label="ph.", phase_number="1", paraphrasis="Place a piece of lead over vinegar in closed jars ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116002" [label="ph.", phase_number="2", paraphrasis="Wait for lead to acquire thickness ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116003" [label="ph.", phase_number="3", paraphrasis="Open the jars ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116004" [label="ph.", phase_number="4", paraphrasis="Scrape away from the lead the substance that has formed on its surface, repeating this until you have consumed it completely ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116005" [label="ph.", phase_number="5", paraphrasis="Grind what you have scraped away ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116006" [label="ph.", phase_number="6", paraphrasis="Filter off what you are grinding ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

"tlg0093_tlg004.q151116007" [label="ph.", phase_number="7", paraphrasis="The final precipitate is lead white ", shape="box", style="rounded,filled", label_color="lightslategrey", color="ghostwhite"];

